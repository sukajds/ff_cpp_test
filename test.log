373af7dc7d2706288a7dffe5.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/N3922VZ63P/N3922VZ63P-eyecatches_d8d576976ec48a27813cee9e9a363b60.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/N3922VZ63P/N3922VZ63P-eyecatches_899cdff38c9a8211847251ff6fc0a27b.jpg","width":640,"height":360}},{"large":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/N3922VZ63P/N3922VZ63P-eyecatches_6728c898ffd9afff9acea5b2013d53c1.jpg","width":3840,"height":2160},"main":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/N3922VZ63P/N3922VZ63P-eyecatches_2ec7ad3875ed43958077d25d6596c6c5.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/N3922VZ63P/N3922VZ63P-eyecatches_57ebef3346e273094030d8a2bc8d1234.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/N3922VZ63P/N3922VZ63P-eyecatches_664e5f109c6564e80616aff2563e02aa.jpg","width":640,"height":360}}],"video":[{"id":"hskOriginal-g1-130-2026030107100","name":"豊臣兄弟！（８）墨俣（すのまた）一夜城","description":"小一郎（仲野太賀）らは墨俣へ出陣。だが信長（小栗旬）の真の狙いは墨俣ではなく、美濃三人衆の一人・安藤守就（田中哲司）が守る北方城だった。藤吉郎（池松壮亮）は、美濃国主・斎藤龍興（濱田龍臣）の目を北方城から逸らすための捨て石と承知の上で、墨俣に砦を築く大作戦に着手する。一方、直（白石聖）は、小一郎と夫婦になる許しを得るため中村に戻る。意外にも父・喜左衛門（大倉孝二）から手厚く迎えられるが・・・","url":"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY/ep/N3922VZ63P","identifierGroup":{"environmentId":"hskOriginal","broadcastEventId":"g1-130-2026030107100","serviceId":"g1","streamType":"vod"},"detailedContentStatus":{"environmentId":"hskOriginal","streamType":"vod","contentStatus":"ready"},"detailedVideoDescriptor":"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260301/1bbc-1-3-7aacee5c250dffd3b0812bbf72420aa7/videoinfo-712d7a03e5f976f8afc44bc4ac5ac21c.json","expires":"2026-03-08T20:44:30+09:00","duration":"PT44M29S","startDate":"2026-03-01T20:00:00+09:00","endDate":"2026-03-01T20:44:30+09:00","isDivided":false,"publication":[{"id":"g1-130-2026030107100","url":"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030107100.json","isLiveBroadcast":true}],"hasPart":[],"uploadDate":"2026-03-01T20:44:30+09:00"}],"citation":[],"detailedPinnedCitation":[{"name":"🐒第8回～の相関図・登場人物はこちら","url":"https://www.nhk.jp/g/ts/P52L88MYXY/blog/bl/pwWYoeNnb2/bp/pnZLZ2B34v/"},{"name":"🐒第8回「墨俣（すのまた）一夜城」まとめ","url":"https://www.nhk.jp/g/ts/P52L88MYXY/blog/bl/pdRPMxDlrQ/bp/pVaqDG19AV/"},{"name":"📺関連番組はこちら（NHK ONE 「豊臣兄弟！」 プレイリスト）","url":"https://www.web.nhk/tv/pl/editorial-tep-4MBMYEIJTX"}],"sameAs":[],"correction":[],"url":"https://api-local.ss.org.nhk/r8/t/tvepisode/te/N3922VZ63P.json","canonical":"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY/ep/N3922VZ63P","associatedMedia":[],"hasPart":[],"additionalProperty":{"episodeMergeStatus":"notMerged"}},"link":{"href":"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY/ep/N3922VZ63P"}}]
2d:["$","$L12","9YN1977VG1",{"content":{"type":"TVEpisode","id":"9YN1977VG1","name":"(7)決死の築城作戦","detailedEpisodeNameRuby":"","identifierGroup":{"tvEpisodeId":"9YN1977VG1","tvSeriesId":"P52L88MYXY","tvEpisodeName":"(7)決死の築城作戦","tvSeriesName":"大河ドラマ「豊臣兄弟！」","hashtag":[],"siteId":"8969","serviceId":["g1","g2","s1","s5"],"aliasId":"toyotomi-kyodai","formatGenreTag":[{"id":"03","name":"ドラマ"}],"themeGenreTag":[{"id":"031","name":"国内ドラマ"},{"id":"033","name":"時代劇"},{"id":"030","name":"ドラマ全般"}]},"keyword":[],"description":"藤吉郎（池松壮亮）は晴れて寧々（浜辺美波）と夫婦に。だが祝言の日、直（白石聖）が中村に帰ると言いだし、小一郎（仲野太賀）は戸惑う。一方、美濃攻めに乗り出した信長（小栗旬）に対し、藤吉郎は要衝・墨俣の攻略を買って出る。小一郎は攻略の秘策を思いつくが、実現には尾張と美濃の国境を仕切る川並衆の協力が必要。２人は、川並衆の棟梁・蜂須賀正勝（高橋努）とよしみのある織田家臣・前野長康（渋谷謙人）に仲介を頼む。","dateCreated":"2026-01-13T18:33:16+09:00","dateModified":"2026-03-02T16:12:56+09:00","actor":[{"person":{"identifierGroup":{"npgId":"29D4D7A7-E3F2-4E1F-94CA-046080070DC0","wikidataId":"Q11444506"},"roleName":"Actor","displayRoleName":"俳優","name":"仲野 太賀","detailedNameRuby":"なかの たいが","familyName":"仲野","givenName":"太賀","detailedFamilyNameRuby":"なかの","detailedGivenNameRuby":"たいが","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_bba932486e9715f0c88077bac28a03a5.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_96550216303231facd956bb116caa614.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_20ad70eaeb107b8f431c2d470fdfdeb2.png","width":200,"height":200}},"characterName":"小一郎（豊臣秀長）","detailedCharacterNameRuby":"こいちろう（とよとみ ひでなが）","description":"天下人・豊臣秀吉の弟\n登場時の名は小一郎。兄の天下取りをいちずに支え続けた「天下一の補佐役」といわれている。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"D690F0C8-05B8-4A71-9A1E-13B8A756E70D","wikidataId":"Q1058963"},"roleName":"Actor","displayRoleName":"俳優","name":"池松 壮亮","detailedNameRuby":"いけまつ そうすけ","familyName":"池松","givenName":"壮亮","detailedFamilyNameRuby":"いけまつ","detailedGivenNameRuby":"そうすけ","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_92f02688b9bd99a554065cd296d2952f.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_cb1f34b797811ceac6d68d9b83e9b8f7.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_87292aa7be724fb75464ac6a068a68fd.png","width":200,"height":200}},"characterName":"藤吉郎（豊臣秀吉）","detailedCharacterNameRuby":"とうきちろう（とよとみ ひでよし）","description":"小一郎を乱世に巻き込んだ野心家の兄\n小一郎の３歳年上の兄。登場時の名は藤吉郎。尾張中村の貧しい農家で生まれ育ったが、主君である戦国武将・織田信長のもとでメキメキと頭角をあらわし、ついには天下統一を果たす。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"04E1F915-FCA1-441E-B5E2-5D60F7FE75D6","wikidataId":"Q11284289"},"roleName":"Actor","displayRoleName":"俳優","name":"浜辺 美波","detailedNameRuby":"はまべ みなみ","familyName":"浜辺","givenName":"美波","detailedFamilyNameRuby":"はまべ","detailedGivenNameRuby":"みなみ","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_18cf0bd1c6f206300d5597fce517f5f8.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_edbfc099c50a27959c381da20788db7c.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_0f5f7e395d69946dd7f47e133e89c342.png","width":200,"height":200}},"characterName":"寧々","detailedCharacterNameRuby":"ねね","description":"夫の秀吉とともに天下人への階段を昇りつめる\n豊臣秀吉の正妻。秀吉が関白に就任したのちは北政所（きたのまんどころ）と称される。\n負けず嫌いの性格で、夫の秀吉とともに出世街道を駆け抜ける。\nやがて庶民の娘から“戦国のファーストレディ”へと昇りつめる。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"00110902-AE66-45F8-B48D-E45DBA3F0CA8","wikidataId":"Q48758750"},"roleName":"Actor","displayRoleName":"俳優","name":"白石 聖","detailedNameRuby":"しらいし せい","familyName":"白石","givenName":"聖","detailedFamilyNameRuby":"しらいし","detailedGivenNameRuby":"せい","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_0fe4352bc0ad486cf90ca333d73f6914.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_20e3755feba331ef7b91101e09b2a1a1.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_a970a9a9542b4d85fbc1027e68068415.png","width":200,"height":200}},"characterName":"直","detailedCharacterNameRuby":"なお","description":"小一郎の幼なじみ“初恋のひと”\n小一郎と藤吉郎の故郷である尾張中村の土豪の娘。小一郎と同い年の幼なじみ。男勝りな性格だが、小一郎のことをひそかに慕っている。乱世に翻弄される悲劇のヒロイン。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"66D5AA5D-8A64-4B6A-ABB7-5292F551EB64","wikidataId":"Q456644"},"roleName":"Actor","displayRoleName":"俳優","name":"坂井 真紀","detailedNameRuby":"さかい まき","familyName":"坂井","givenName":"真紀","detailedFamilyNameRuby":"さかい","detailedGivenNameRuby":"まき","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_be82055d1422408d4df158e98f8e70e9.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_297fac5c0abd7f590defc6551b0785b1.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_e602af3899bd45ae871f300d77aeb2ae.png","width":200,"height":200}},"characterName":"なか","detailedCharacterNameRuby":"","description":"息子たちの出世を温かく見守る母\n豊臣兄弟の母。夫を早くに亡くし、女手一つで二男二女を育てる。息子たちの異例の出世に喜びやとまどいを感じながらも温かく見守り、天下人となった秀吉が関白に就任すると「大政所（おおまんどころ）」と称されるようになる。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"95D8852C-551F-4464-8309-F469B5AF370F","wikidataId":"Q11347265"},"roleName":"Actor","displayRoleName":"俳優","name":"宮澤 エマ","detailedNameRuby":"みやざわ えま","familyName":"宮澤","givenName":"エマ","detailedFamilyNameRuby":"みやざわ","detailedGivenNameRuby":"えま","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_4a2733a3a570bd47a234c505111cda69.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_ad814d5694869f12180526033d359037.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_62932afd84cec409aee9c6a465dbcf59.png","width":200,"height":200}},"characterName":"とも","detailedCharacterNameRuby":"","description":"兄弟に厳しくあたるしっかり者の姉\n豊臣兄弟の姉。しっかり者で負けん気が強い。三人の男児を産み育てるが、跡継ぎに恵まれなかった弟の秀吉によって政治の道具として利用される。のちに秀吉の後継者となった長男の秀次は謀反の疑いをかけられ妻子とともに処刑されることになる。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"0AB5B169-08AF-4793-B060-4E2771CBA976","wikidataId":"Q11671066"},"roleName":"Actor","displayRoleName":"俳優","name":"高橋 努","detailedNameRuby":"たかはし つとむ","familyName":"高橋","givenName":"努","detailedFamilyNameRuby":"たかはし","detailedGivenNameRuby":"つとむ","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_ac54e3823f28798d4c09b72cd0b38eda.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_babe0d64a43162a7d1b95cf957604482.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_4f24d1cb71aeaa50d26714ec9fdb6939.png","width":200,"height":200}},"characterName":"蜂須賀正勝","detailedCharacterNameRuby":"はちすか まさかつ","description":"川並衆筆頭\n木曽川での運送に携わる土豪。美濃の要地・墨俣に砦（とりで）の築城を命じられた豊臣兄弟は、正勝に協力を求める。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"E0663954-2B45-4A7D-A804-3D3B986EE4F0","wikidataId":"Q11561773"},"roleName":"Actor","displayRoleName":"俳優","name":"渋谷 謙人","detailedNameRuby":"しぶや けんと","familyName":"渋谷","givenName":"謙人","detailedFamilyNameRuby":"しぶや","detailedGivenNameRuby":"けんと","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_9133aaa983bc553872aa52f8f99a89f8.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_70401a077714026eb9c35d00375d7155.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_d50ac474ae040bc4dc9f4a9c83eb41c9.png","width":200,"height":200}},"characterName":"前野長康","detailedCharacterNameRuby":"まえの ながやす","description":"織田家の家臣\n正勝と義兄弟の契りを結ぶも、織田家に仕えたため疎遠に。豊臣兄弟から、正勝との橋渡しを頼まれる。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"33A709F5-6B0B-4AC2-A757-3EE61BAEAA68","wikidataId":"Q11467539"},"roleName":"Actor","displayRoleName":"俳優","name":"山口 馬木也","detailedNameRuby":"やまぐち まきや","familyName":"山口","givenName":"馬木也","detailedFamilyNameRuby":"やまぐち","detailedGivenNameRuby":"まきや","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_15931ec1d4d47a797b3f63471e4f8cb1.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_79787545c1c002b53053bdf991bc18bd.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_87776243a43926e281a519ccc036edd0.png","width":200,"height":200}},"characterName":"柴田勝家","detailedCharacterNameRuby":"しばた かついえ","description":"兄弟の前に立ちはだかる大きな壁\n織田信長の重臣の一人。勇猛果敢な戦上手で「鬼柴田」の異名で恐れられた。足軽時代の小一郎と藤吉郎にとっては怖くて苦手な存在。やがて二人が出世を果たすとあからさまに毛嫌いするようになる。信長亡きあとの「清須会議」では後継者争いを繰り広げ、やがて「賤ケ岳の戦い」で兄弟と激突することになる。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"F8A68291-926B-4D78-92E8-DA8D8B46ABAF","wikidataId":"Q457825"},"roleName":"Actor","displayRoleName":"俳優","name":"小栗 旬","detailedNameRuby":"おぐり しゅん","familyName":"小栗","givenName":"旬","detailedFamilyNameRuby":"おぐり","detailedGivenNameRuby":"しゅん","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_67abfcde9f1ca7f00a22417945168442.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_0a1e60b5d188f3db10e7dd344d64d75f.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_78b15fdd0397ff4e3ccaf14cd51bac26.png","width":200,"height":200}},"characterName":"織田信長","detailedCharacterNameRuby":"おだ のぶなが","description":"天下一統を狙う孤高のカリスマ\n大胆で革新的な戦略と非凡なリーダーシップにより領土を拡大し、「天下布武」のスローガンのもと天下一統を目指したカリスマ的武将。立身出世を目指す小一郎（のちの秀長）と藤吉郎（のちの秀吉）兄弟にとって絶対的な主君である。当主争いで対立した弟を自らの手で殺害したという苦い過去を持っている。","detailedWork":[],"hasOccupation":[]}}],"contributor":[],"partOfSeries":{"id":"P52L88MYXY","name":"大河ドラマ「豊臣兄弟！」","detailedSeriesNameRuby":"とよとみきょうだい","identifierGroup":{"tvSeriesId":"P52L88MYXY","tvSeriesPlaylistId":"series-tep-P52L88MYXY","tvSeriesUId":"p0defc81f-a07b-55e0-b9a6-c7f75720f416","tvSeriesName":"大河ドラマ「豊臣兄弟！」","hashtag":[],"siteId":"8969","serviceId":["g1","g2","s1","s2","s5"],"aliasId":"toyotomi-kyodai","formatGenre":[{"id":"03","name":"ドラマ"}],"nod":{"id":"P202500491700000","url":"https://www.nhk-ondemand.jp/program/P202500491700000/"}},"keyword":["NHK","大河ドラマ","豊臣兄弟！","戦国時代","豊臣秀長","豊臣秀吉","八津弘幸","仲野太賀","池松壮亮","吉岡里帆","浜辺美波","白石聖","坂井真紀","宮澤エマ","大東駿介","松下洸平","山口馬木也","宮﨑あおい","小栗旬"],"detailedSynonym":[],"sameAs":[{"name":"▶︎公式Instagram アカウント","url":"https://www.instagram.com/nhk_toyotomi/"},{"name":"▶︎公式X（旧Twitter）アカウント","url":"https://x.com/nhk_toyotomi"},{"name":"▶︎NHK公式YouTube「豊臣兄弟！」プレイリスト","url":"https://www.youtube.com/playlist?list=PLcynJ47QaWNvaqX7QpxWQbRs1tHrRHgnb"}],"canonical":"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY","description":"【NHK公式】大河ドラマ「豊臣兄弟！」\n\n大河ドラマ第65作で描くのは、戦国時代のど真ん中!!\n強い絆で天下統一という偉業を成し遂げた豊臣兄弟の奇跡──\n夢と希望の下剋上（げこくじょう）サクセスストーリーです！\n\n主人公は天下人の弟・豊臣秀長（とよとみ・ひでなが）\n歴史にif（もしも）はないものの…\n\n『秀長が長生きしていれば豊臣家の天下は安泰だった』\n\nとまでいわしめた天下一の補佐役・秀長の目線で戦国時代をダイナミックに描く波乱万丈のエンターテインメント！\n\n【放送予定】\n2026年1月4日（日）スタート ※初回15分拡大版\n\n【作】八津弘幸\n【音楽】木村秀彬\n【語り】安藤サクラ\n【出演】仲野太賀、池松壮亮、吉岡里帆、浜辺美波、白石 聖、坂井真紀、宮澤エマ、菅田将暉、大東駿介、松下洸平、山口馬木也、宮﨑あおい、小栗 旬　ほか\n【時代考証】黒田基樹、柴 裕之\n【制作統括】松川博敬、堀内裕介\n【プロデューサー】高橋優香子、舟橋哲男、吉岡和彦（展開・プロモーション）、国友 茜（広報）\n【演出】渡邊良雄、渡辺哲也、田中 正","detailedCatch":"熱い兄弟が夢と希望を胸に突っ走る奇跡の下剋上サクセスストーリー！","logo":{"main":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_c64ecc100161d9ce85c8aa953bc73ae1.jpg","width":1080,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_64a636dd72417d3cf661cb2f6808c33a.jpg","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_b696c913daeb18f3a663376fa0ec438b.jpg","width":200,"height":200}},"eyecatch":{"large":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-eyecatch_a738f4a4bd6c933e48839aa43eb14379.jpg","width":3840,"height":2160},"main":{"url":"https://imgu.web.nhk/static/assets/images/tvs