pi-local.ss.org.nhk/r8/t/tvepisode/te/N3RJVK953X.json\",\"canonical\":\"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY/ep/N3RJVK953X\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY/ep/N3RJVK953X\"}}]\n"])</script><script>self.__next_f.push([1,"49:[\"$\",\"$L2a\",\"5GNQ8QWWNV\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"5GNQ8QWWNV\",\"name\":\"(3)決戦前夜\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"5GNQ8QWWNV\",\"tvSeriesId\":\"P52L88MYXY\",\"tvEpisodeName\":\"(3)決戦前夜\",\"tvSeriesName\":\"大河ドラマ「豊臣兄弟！」\",\"hashtag\":[],\"siteId\":\"8969\",\"serviceId\":[\"g1\",\"g2\",\"s1\",\"s2\",\"s5\"],\"aliasId\":\"toyotomi-kyodai\",\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"},{\"id\":\"033\",\"name\":\"時代劇\"},{\"id\":\"030\",\"name\":\"ドラマ全般\"}]},\"keyword\":[],\"description\":\"故郷の中村をあとにした小一郎（仲野太賀）、藤吉郎（池松壮亮）、直（白石聖）の３人は織田信長（小栗旬）の城下町・清須にやってくる。織田家臣の浅野長勝（宮川一朗太）のもとに挨拶に訪れるが、その場で直は長勝の娘・寧々（浜辺美波）の侍女になることが決まる。兄弟の二人三脚の暮らしが始まるが、藤吉郎は小一郎にある秘密の計画を打ち明ける。そしてついに今川義元（大鶴義丹）の大軍が尾張に向けて進軍を始める。\",\"dateCreated\":\"2025-11-25T18:34:51+09:00\",\"dateModified\":\"2026-01-31T00:03:36+09:00\",\"actor\":[{\"person\":{\"identifierGroup\":{\"npgId\":\"29D4D7A7-E3F2-4E1F-94CA-046080070DC0\",\"wikidataId\":\"Q11444506\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"仲野 太賀\",\"detailedNameRuby\":\"なかの たいが\",\"familyName\":\"仲野\",\"givenName\":\"太賀\",\"detailedFamilyNameRuby\":\"なかの\",\"detailedGivenNameRuby\":\"たいが\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_bba932486e9715f0c88077bac28a03a5.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_96550216303231facd956bb116caa614.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_20ad70eaeb107b8f431c2d470fdfdeb2.png\",\"width\":200,\"height\":200}},\"characterName\":\"小一郎（豊臣秀長）\",\"detailedCharacterNameRuby\":\"こいちろう（とよとみ ひでなが）\",\"description\":\"天下人・豊臣秀吉の弟\\n登場時の名は小一郎。兄の天下取りをいちずに支え続けた「天下一の補佐役」といわれている。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"D690F0C8-05B8-4A71-9A1E-13B8A756E70D\",\"wikidataId\":\"Q1058963\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"池松 壮亮\",\"detailedNameRuby\":\"いけまつ そうすけ\",\"familyName\":\"池松\",\"givenName\":\"壮亮\",\"detailedFamilyNameRuby\":\"いけまつ\",\"detailedGivenNameRuby\":\"そうすけ\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_92f02688b9bd99a554065cd296d2952f.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_cb1f34b797811ceac6d68d9b83e9b8f7.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_87292aa7be724fb75464ac6a068a68fd.png\",\"width\":200,\"height\":200}},\"characterName\":\"藤吉郎（豊臣秀吉）\",\"detailedCharacterNameRuby\":\"とうきちろう（とよとみ ひでよし）\",\"description\":\"小一郎を乱世に巻き込んだ野心家の兄\\n小一郎の３歳年上の兄。登場時の名は藤吉郎。尾張中村の貧しい農家で生まれ育ったが、主君である戦国武将・織田信長のもとでメキメキと頭角をあらわし、ついには天下統一を果たす。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"04E1F915-FCA1-441E-B5E2-5D60F7FE75D6\",\"wikidataId\":\"Q11284289\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"浜辺 美波\",\"detailedNameRuby\":\"はまべ みなみ\",\"familyName\":\"浜辺\",\"givenName\":\"美波\",\"detailedFamilyNameRuby\":\"はまべ\",\"detailedGivenNameRuby\":\"みなみ\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_18cf0bd1c6f206300d5597fce517f5f8.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_edbfc099c50a27959c381da20788db7c.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_0f5f7e395d69946dd7f47e133e89c342.png\",\"width\":200,\"height\":200}},\"characterName\":\"寧々\",\"detailedCharacterNameRuby\":\"ねね\",\"description\":\"夫の秀吉とともに天下人への階段を昇りつめる\\n豊臣秀吉の正妻。秀吉が関白に就任したのちは北政所（きたのまんどころ）と称される。\\n負けず嫌いの性格で、夫の秀吉とともに出世街道を駆け抜ける。\\nやがて庶民の娘から“戦国のファーストレディ”へと昇りつめる。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"00110902-AE66-45F8-B48D-E45DBA3F0CA8\",\"wikidataId\":\"Q48758750\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"白石 聖\",\"detailedNameRuby\":\"しらいし せい\",\"familyName\":\"白石\",\"givenName\":\"聖\",\"detailedFamilyNameRuby\":\"しらいし\",\"detailedGivenNameRuby\":\"せい\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_0fe4352bc0ad486cf90ca333d73f6914.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_20e3755feba331ef7b91101e09b2a1a1.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_a970a9a9542b4d85fbc1027e68068415.png\",\"width\":200,\"height\":200}},\"characterName\":\"直\",\"detailedCharacterNameRuby\":\"なお\",\"description\":\"小一郎の幼なじみ“初恋のひと”\\n小一郎と藤吉郎の故郷である尾張中村の土豪の娘。小一郎と同い年の幼なじみ。男勝りな性格だが、小一郎のことをひそかに慕っている。乱世に翻弄される悲劇のヒロイン。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"A8A7AFA3-BF8A-4C77-A8AA-4E52145F1E3C\",\"wikidataId\":\"Q3543884\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"加治 将樹\",\"detailedNameRuby\":\"かじ まさき\",\"familyName\":\"加治\",\"givenName\":\"将樹\",\"detailedFamilyNameRuby\":\"かじ\",\"detailedGivenNameRuby\":\"まさき\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_634e7bc498fb6d23dc15aab6219e3ba0.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_7626f52e72efb35590caa42682930f39.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_424c0af47228b7e421fb4a4e0e94584b.png\",\"width\":200,\"height\":200}},\"characterName\":\"城戸小左衛門\",\"detailedCharacterNameRuby\":\"きど こざえもん\",\"description\":\"織田家の家臣\\n織田家中で一目置かれる槍（やり）の名人。小一郎と藤吉郎の父・弥右衛門と因縁があるようで……。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"F6611598-AA03-431B-A0F7-C341462A80E5\",\"wikidataId\":\"Q11528970\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"松下 洸平\",\"detailedNameRuby\":\"まつした こうへい\",\"familyName\":\"松下\",\"givenName\":\"洸平\",\"detailedFamilyNameRuby\":\"まつした\",\"detailedGivenNameRuby\":\"こうへい\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_8affe6a71dfbda2c3e04e856b5807321.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_ce27b072ff776320688a40d716d789f3.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_845231c9e73496feead8fef6492fedef.png\",\"width\":200,\"height\":200}},\"characterName\":\"徳川家康\",\"detailedCharacterNameRuby\":\"とくがわ いえやす\",\"description\":\"豊臣兄弟の最強のライバル\\n戦国乱世に終止符を打ち、江戸幕府初代将軍として泰平の世を築いた戦国三英傑の一人。「桶狭間の戦い」で主君の今川義元が信長に討たれたことで、その後の運命が大きく変わることに。信長亡きあと天下一統を狙う豊臣兄弟の眼前に最大最強のライバルとして立ちはだかる。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"0BBFC4C3-B711-4621-B988-BA3D6838C04C\",\"wikidataId\":\"Q11442004\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"大鶴 義丹\",\"detailedNameRuby\":\"おおつる ぎたん\",\"familyName\":\"大鶴\",\"givenName\":\"義丹\",\"detailedFamilyNameRuby\":\"おおつる\",\"detailedGivenNameRuby\":\"ぎたん\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_3ae94c2385bac371d0503eb8faef7ee7.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_8411d95cd5424d0aaa8d66d42136b30a.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_1ea16f142cf0ecd31dddaa740809e6d1.png\",\"width\":200,\"height\":200}},\"characterName\":\"今川義元\",\"detailedCharacterNameRuby\":\"いまがわ よしもと\",\"description\":\"駿河・遠江の戦国大名\\n東海道の広大な地域を支配する駿河の戦国大名。教養に富み、領地をよく治め、軍事的手腕にも優れていたことから、のちに“海道一の弓取り”と称される。大軍を率いて尾張国東部をめぐる織田信長との戦いに臨む。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"33A709F5-6B0B-4AC2-A757-3EE61BAEAA68\",\"wikidataId\":\"Q11467539\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"山口 馬木也\",\"detailedNameRuby\":\"やまぐち まきや\",\"familyName\":\"山口\",\"givenName\":\"馬木也\",\"detailedFamilyNameRuby\":\"やまぐち\",\"detailedGivenNameRuby\":\"まきや\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_15931ec1d4d47a797b3f63471e4f8cb1.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_79787545c1c002b53053bdf991bc18bd.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_87776243a43926e281a519ccc036edd0.png\",\"width\":200,\"height\":200}},\"characterName\":\"柴田勝家\",\"detailedCharacterNameRuby\":\"しばた かついえ\",\"description\":\"兄弟の前に立ちはだかる大きな壁\\n織田信長の重臣の一人。勇猛果敢な戦上手で「鬼柴田」の異名で恐れられた。足軽時代の小一郎と藤吉郎にとっては怖くて苦手な存在。やがて二人が出世を果たすとあからさまに毛嫌いするようになる。信長亡きあとの「清須会議」では後継者争いを繰り広げ、やがて「賤ケ岳の戦い」で兄弟と激突することになる。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"DF67D531-44A9-491B-8A45-E373107544BA\",\"wikidataId\":\"Q253873\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"宮﨑 あおい\",\"detailedNameRuby\":\"みやざき あおい\",\"familyName\":\"宮﨑\",\"givenName\":\"あおい\",\"detailedFamilyNameRuby\":\"みやざき\",\"detailedGivenNameRuby\":\"あおい\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_c10ea05d98950386bb1e035c703385fb.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_863cae13c5e3efd46d2bcb715a68650a.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_9c29c4086e33985389330e70402d42d9.png\",\"width\":200,\"height\":200}},\"characterName\":\"市\",\"detailedCharacterNameRuby\":\"いち\",\"description\":\"波乱の生涯を歩む戦国ヒロイン\\n織田信長の妹。乱世に翻弄され悲劇的な一生を送るが、兄・信長と織田家のため波乱万丈な生涯を毅然（きぜん）として生き抜いた戦国ヒロインのひとり。信長と同盟を結ぶ近江の浅井長政に嫁ぎ、茶々・初・江の三姉妹を生み育てるが、のちに兄と夫が対立することになる。\",\"detailedWork\":[],\"hasOccupation\":[]}},{\"person\":{\"identifierGroup\":{\"npgId\":\"F8A68291-926B-4D78-92E8-DA8D8B46ABAF\",\"wikidataId\":\"Q457825\"},\"roleName\":\"Actor\",\"displayRoleName\":\"俳優\",\"name\":\"小栗 旬\",\"detailedNameRuby\":\"おぐり しゅん\",\"familyName\":\"小栗\",\"givenName\":\"旬\",\"detailedFamilyNameRuby\":\"おぐり\",\"detailedGivenNameRuby\":\"しゅん\",\"detailedNameDescription\":\"\",\"honorificSuffix\":\"\",\"jobTitle\":[],\"memberOf\":[],\"image\":{\"main\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_67abfcde9f1ca7f00a22417945168442.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_0a1e60b5d188f3db10e7dd344d64d75f.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_78b15fdd0397ff4e3ccaf14cd51bac26.png\",\"width\":200,\"height\":200}},\"characterName\":\"織田信長\",\"detailedCharacterNameRuby\":\"おだ のぶなが\",\"description\":\"天下一統を狙う孤高のカリスマ\\n大胆で革新的な戦略と非凡なリーダーシップにより領土を拡大し、「天下布武」のスローガンのもと天下一統を目指したカリスマ的武将。立身出世を目指す小一郎（のちの秀長）と藤吉郎（のちの秀吉）兄弟にとって絶対的な主君である。当主争いで対立した弟を自らの手で殺害したという苦い過去を持っている。\",\"detailedWork\":[],\"hasOccupation\":[]}}],\"contributor\":[],\"partOfSeries\":{\"id\":\"P52L88MYXY\",\"name\":\"大河ドラマ「豊臣兄弟！」\",\"detailedSeriesNameRuby\":\"とよとみきょうだい\",\"identifierGroup\":{\"tvSeriesId\":\"P52L88MYXY\",\"tvSeriesPlaylistId\":\"series-tep-P52L88MYXY\",\"tvSeriesUId\":\"p0defc81f-a07b-55e0-b9a6-c7f75720f416\",\"tvSeriesName\":\"大河ドラマ「豊臣兄弟！」\",\"hashtag\":[],\"siteId\":\"8969\",\"serviceId\":[\"g1\",\"g2\",\"s1\",\"s2\",\"s5\"],\"aliasId\":\"toyotomi-kyodai\",\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"nod\":{\"id\":\"P202500491700000\",\"url\":\"https://www.nhk-ondemand.jp/program/P202500491700000/\"}},\"keyword\":[\"NHK\",\"大河ドラマ\",\"豊臣兄弟！\",\"戦国時代\",\"豊臣秀長\",\"豊臣秀吉\",\"八津弘幸\",\"仲野太賀\",\"池松壮亮\",\"吉岡里帆\",\"浜辺美波\",\"白石聖\",\"坂井真紀\",\"宮澤エマ\",\"大東駿介\",\"松下洸平\",\"山口馬木也\",\"宮﨑あおい\",\"小栗旬\"],\"detailedSynonym\":[],\"sameAs\":[{\"name\":\"▶︎公式Instagram アカウント\",\"url\":\"https://www.instagram.com/nhk_toyotomi/\"},{\"name\":\"▶︎公式X（旧Twitter）アカウント\",\"url\":\"https://x.com/nhk_toyotomi\"},{\"name\":\"▶︎NHK公式YouTube「豊臣兄弟！」プレイリスト\",\"url\":\"https://www.youtube.com/playlist?list=PLcynJ47QaWNvaqX7QpxWQbRs1tHrRHgnb\"}],\"canonical\":\"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY\",\"description\":\"【NHK公式】大河ドラマ「豊臣兄弟！」\\n\\n大河ドラマ第65作で描くのは、戦国時代のど真ん中!!\\n強い絆で天下統一という偉業を成し遂げた豊臣兄弟の奇跡──\\n夢と希望の下剋上（げこくじょう）サクセスストーリーです！\\n\\n主人公は天下人の弟・豊臣秀長（とよとみ・ひでなが）\\n歴史にif（もしも）はないものの…\\n\\n『秀長が長生きしていれば豊臣家の天下は安泰だった』\\n\\nとまでいわしめた天下一の補佐役・秀長の目線で戦国時代をダイナミックに描く波乱万丈のエンターテインメント！\\n\\n【放送予定】\\n2026年1月4日（日）スタート ※初回15分拡大版\\n\\n【作】八津弘幸\\n【音楽】木村秀彬\\n【語り】安藤サクラ\\n【出演】仲野太賀、池松壮亮、吉岡里帆、浜辺美波、白石 聖、坂井真紀、宮澤エマ、菅田将暉、大東駿介、松下洸平、山口馬木也、宮﨑あおい、小栗 旬　ほか\\n【時代考証】黒田基樹、柴 裕之\\n【制作統括】松川博敬、堀内裕介\\n【プロデューサー】高橋優香子、舟橋哲男、吉岡和彦（展開・プロモーション）、国友 茜（広報）\\n【演出】渡邊良雄、渡辺哲也、田中 正\",\"detailedCatch\":\"熱い兄弟が夢と希望を胸に突っ走る奇跡の下剋上サクセスストーリー！\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_c64ecc100161d9ce85c8aa953bc73ae1.jpg\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_64a636dd72417d3cf661cb2f6808c33a.jpg\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_b696c913daeb18f3a663376fa0ec438b.jpg\",\"width\":200,\"height\":200}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-eyecatch_a738f4a4bd6c933e48839aa43eb14379.jpg\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-eyecatch_db018d96e8b0a9b57d8a66adf2895c55.jpg\",\"width\":1920,\"height\":1