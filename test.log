0,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/M7KV55MNXY/M7KV55MNXY-eyecatches_49d858a1ca43b81f811de8ff459b5ba8.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/M7KV55MNXY/M7KV55MNXY-eyecatches_bac9b80cad75ff456f1a3537ef496f69.jpg\",\"width\":640,\"height\":360}}],\"video\":[{\"id\":\"hskOriginal-g1-130-2026031313346\",\"name\":\"【連続テレビ小説】ばけばけ（１１５）第２３週「ゴブサタ、ニシコオリサン。」\",\"description\":\"久しぶりに松江の朝を迎えたヘブン（トミー・バストウ）。しかし、かつて感じたはずの感情が、音を聞いても、風景を見ても、なにも感じられない。自分の変化に動揺するヘブンに声をかけたのは、錦織（吉沢亮）だった。声をかけられたヘブンは、自分は八雲だ、日本人だと告げる。そんなヘブンに、錦織は日本人になる意味、錦織が反対する理由、ヘブンの現実を淡々と突き付ける。そんな二人の様子をトキ（髙石あかり）は目撃する。\",\"url\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/M7KV55MNXY\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026031313346\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"notyet\"},\"detailedVideoDescriptor\":\"https://simul.hsk.st.nhk/npd3/7fe0-0400/20260313/3422-1-1-333c7802c8de10f66393a245660ef175/videoinfo-07aa8692938475fb84f49fb921ac3732.json\",\"expires\":\"2026-03-20T08:15:00+09:00\",\"duration\":\"PT15M\",\"startDate\":\"2026-03-13T08:00:00+09:00\",\"endDate\":\"2026-03-13T08:15:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026031313346\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026031313346.json\",\"isLiveBroadcast\":true}],\"uploadDate\":\"2026-03-13T08:15:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[{\"name\":\"✨登場人物・キャスト\",\"url\":\"https://www.nhk.jp/g/ts/662ZX5J3WG/blog/bl/p63MOdwNjk/bp/pnyMroAvAn/\"},{\"name\":\"📺関連番組・インタビューはこちらから\",\"url\":\"https://www.nhk.jp/g/ts/662ZX5J3WG/blog/bl/p7xRqmNdbW/\"},{\"name\":\"📢ＮＨＫオンデマンドでは第1回から配信中\",\"url\":\"https://www.nhk-ondemand.jp/program/P202500475400000/\"}],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/M7KV55MNXY.json\",\"canonical\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/M7KV55MNXY\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/M7KV55MNXY\"}}]\n"])</script><script>self.__next_f.push([1,"4d:[\"$\",\"$L2a\",\"RKWMR8L56W\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"RKWMR8L56W\",\"name\":\"(114)第23週「ゴブサタ、ニシコオリサン。」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"RKWMR8L56W\",\"tvSeriesId\":\"662ZX5J3WG\",\"tvEpisodeName\":\"(114)第23週「ゴブサタ、ニシコオリサン。」\",\"tvSeriesName\":\"ばけばけ\",\"hashtag\":[],\"siteId\":\"0006\",\"serviceId\":[\"g1\",\"g2\",\"s1\",\"s2\",\"s5\"],\"aliasId\":\"bakebake\",\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"},{\"id\":\"030\",\"name\":\"ドラマ全般\"}]},\"keyword\":[],\"description\":\"知事（佐野史郎）に、ヘブン（トミー・バストウ）が日本人になる許可をもらいに訪れたトキ（髙石あかり）とヘブン。しかし、取り付く島もなく一蹴されてしまう。錦織（吉沢亮）に協力を頼もうと中学校を訪れたトキは、そこでサワ（円井わん）と再会する。やはり、錦織に断られてしまうトキ。失意の中、トキとヘブンの元に勘右衛門（小日向文世）が訪ねてくる。日本人になるヘブンに、勘右衛門は名前を考えてきたと告げる。\",\"dateCreated\":\"2025-12-19T18:20:41+09:00\",\"dateModified\":\"2026-03-05T07:30:15+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"662ZX5J3WG\",\"name\":\"ばけばけ\",\"detailedSeriesNameRuby\":\"ばけばけ\",\"identifierGroup\":{\"tvSeriesId\":\"662ZX5J3WG\",\"tvSeriesPlaylistId\":\"series-tep-662ZX5J3WG\",\"tvSeriesUId\":\"p97f04323-5f03-5c6a-ae95-69101ff72127\",\"tvSeriesName\":\"ばけばけ\",\"hashtag\":[],\"siteId\":\"0006\",\"serviceId\":[\"g1\",\"g2\",\"s1\",\"s2\",\"s5\"],\"aliasId\":\"bakebake\",\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[],\"canonical\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG\",\"description\":\"【ＮＨＫ朝ドラ公式】連続テレビ小説「ばけばけ」。主演は髙石あかり。\\nキャスト相関図・見逃し配信・あらすじ・放送予定など。\\n小泉セツ\u0026八雲（ラフカディオ・ハーン）夫妻がモデルの物語。明治の松江。怪談を愛する夫婦の何気ない日常を描きます。\\n\\n【作】ふじきみつ彦\\n【音楽】牛尾憲輔\\n【主題歌】ハンバート ハンバート「笑ったり転んだり」\\n【キャスト】髙石あかり、トミー・バストウ / 吉沢亮　ほか\\n【放送予定】2025年9月29日（月）放送開始 （全25週125回）\",\"detailedCatch\":\"「この世はうらめしい。けど、すばらしい。」\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-logo_c082378e129bdef8d8cc9b0b32d2349c.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-logo_9638d94a4c0f54c68db3481308026a2d.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-logo_907c885a543694caf6cec07746e00fd9.png\",\"width\":200,\"height\":200}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-eyecatch_f921ca54baff6aaf68b140ce9c59d273.png\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-eyecatch_ebc0fbef1eef505881258e06e093ee97.png\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-eyecatch_b045d0c555a786b3a438b87bb5de7473.png\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-eyecatch_0959e71c25448d316c13b769bc79186d.png\",\"width\":640,\"height\":360}},\"hero\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-hero_880e6c4fdacadf3094ba9d4a5e3134b0.png\",\"width\":1920,\"height\":640},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/662ZX5J3WG/662ZX5J3WG-hero_192d043cd8197adb42ddd46fdd996333.png\",\"width\":1080,\"height\":360}},\"style\":{\"textLight\":\"#000000\",\"textDark\":\"#FFFFFF\",\"linkLight\":\"#7E7A00\",\"linkDark\":\"#FAF100\",\"primaryLight\":\"#9E9900\",\"primaryDark\":\"#FAF100\"},\