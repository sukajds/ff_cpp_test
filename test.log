.jpg\",\"width\":640,\"height\":360}},{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/V79QN34LZ7/V79QN34LZ7-eyecatches_e311fdcd5290dbd3b65279fe67be6a23.jpg\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/V79QN34LZ7/V79QN34LZ7-eyecatches_8d2974c4cbfef6d7778495f6155c797b.jpg\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/V79QN34LZ7/V79QN34LZ7-eyecatches_8026806d5645e996e1c8e813babb485d.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/V79QN34LZ7/V79QN34LZ7-eyecatches_b4123e61f26dbf86807fb097e1c6f43f.jpg\",\"width\":640,\"height\":360}}],\"video\":[{\"id\":\"hskOriginal-g1-130-2026030811119\",\"name\":\"豊臣兄弟！（９）竹中半兵衛という男\",\"description\":\"直（白石聖）の死を悼む間もないまま、小一郎（仲野太賀）は美濃国主・斎藤龍興（濱田龍臣）の家臣、竹中半兵衛（菅田将暉）の調略に向かう。だが知恵者と名高い半兵衛は相当の変わり者で、小一郎と藤吉郎（池松壮亮）は翻弄される。その一方で、２人は斎藤家重臣・安藤守就（田中哲司）から思わぬ申し出を受ける。兄弟の報告を聞いた信長（小栗旬）は龍興の居城を包囲するも、窮地の龍興の前に半兵衛があらわれる。\",\"url\":\"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY/ep/V79QN34LZ7\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030811119\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"notyet\"},\"detailedVideoDescriptor\":\"https://simul.hsk.st.nhk/npd3/7fe0-0400/20260308/2b6f-1-1-51a8a99778d292c5d5edff242bf16014/videoinfo-f8e6620ce8922fa726eb3b942b407b95.json\",\"expires\":\"2026-03-15T20:44:30+09:00\",\"duration\":\"PT44M30S\",\"startDate\":\"2026-03-08T20:00:00+09:00\",\"endDate\":\"2026-03-08T20:44:30+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030811119\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030811119.json\",\"isLiveBroadcast\":true}],\"uploadDate\":\"2026-03-08T20:44:30+09:00\"}],\"citation\":[],\"detailedPin