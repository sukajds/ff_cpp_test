\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-logo_200x200.png\",\"width\":200,\"height\":200}},\"eyecatch\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-eyecatch.svg\",\"large\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-eyecatch_3840x2160.png\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-eyecatch_1920x1080.png\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-eyecatch_1280x720.png\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-eyecatch_640x360.png\",\"width\":640,\"height\":360}},\"hero\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero.svg\",\"main\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero_1920x640.png\",\"width\":1920,\"height\":640},\"medium\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero_1080x360.png\",\"width\":1080,\"height\":360}},\"badge9x4\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4.svg\",\"main\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4_360x160.png\",\"width\":360,\"height\":160},\"small\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4_180x80.png\",\"width\":180,\"height\":80}}}},\"eyecatchList\":[],\"video\":[{\"id\":\"hskOriginal-g1-130-2026030107018\",\"name\":\"【特選！時代劇】茂七の事件簿・新ふしぎ草紙（３）「鬼子母火」\",\"description\":\"回向院の茂七（高橋英樹）は、新川の酒問屋・伊丹屋で起きたぼや騒ぎの真相を探ることになる。女中頭のおとよ（木の実ナナ）は、「内々で始末をつけるから関わらないで」というが、神棚のしめ縄に残された髪の毛を手がかりに、奉公人たちや店の内情を調べていく茂七。やがて事件の裏に潜む、人知れぬ思いと幼い奉公人の悲しい過去が浮かび上がる。茂七は江戸の町で起きた小さな火事に、人の情と向き合いながら決着をつけていく。\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-EG75YWMKNN/ep/E6YP71XNZN\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030107018\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"ready\"},\"detailedVideoDescriptor\":\"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260301/1b6a-1-3-e375e43b5734782a3284dda27024acb7/videoinfo-602a90bced017df86f8305ec5cfd4652.json\",\"expires\":\"2026-03-08T06:53:00+09:00\",\"duration\":\"PT42M59S\",\"startDate\":\"2026-03-01T06:10:00+09:00\",\"endDate\":\"2026-03-01T06:53:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030107018\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030107018.json\",\"isLiveBroadcast\":true}],\"hasPart\":[],\"uploadDate\":\"2026-03-01T06:53:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/E6YP71XNZN.json\",\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-EG75YWMKNN/ep/E6YP71XNZN\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/pl/series-tep-EG75YWMKNN/ep/E6YP71XNZN\"}}]\n"])</script><script>self.__next_f.push([1,"5f:[\"$\",\"$L2a\",\"KGG47K5J94\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"KGG47K5J94\",\"name\":\"(2)「落ち葉なしの椎」\",\"identifierGroup\":{\"tvEpisodeId\":\"KGG47K5J94\",\"tvSeriesId\":\"EG75YWMKNN\",\"tvEpisodeName\":\"(2)「落ち葉なしの椎」\",\"tvSeriesName\":\"茂七の事件簿・新ふしぎ草紙\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"},{\"id\":\"033\",\"name\":\"時代劇\"}]},\"keyword\":[],\"description\":\"江戸・本所で商人がかんざしで殺される事件が発生。回向院の茂七（高橋英樹）は、現場に落ち葉が散乱し足跡が消えたことを残念がる。やがて雑穀問屋の奉公人・おしの（吉野紗香）が、落ち葉掃きを続ける異様な行動を見せる。彼女の過去には、父を憎みながらも忘れられない思いがあった。調べを進める茂七は、島流しから戻った女おしげ（筒井真理子）が下手人であることを突き止め、糸吉（伊崎充則）におしのの身辺を警戒させる。\",\"dateCreated\":\"2026-01-29T18:27:06+09:00\",\"dateModified\":\"2026-02-15T04:35:34+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"EG75YWMKNN\",\"name\":\"茂七の事件簿・新ふしぎ草紙\",\"detailedSeriesNameRuby\":\"もしちのじけんぼ　しんふしぎそうし\",\"identifierGroup\":{\"tvSeriesId\":\"EG75YWMKNN\",\"tvSeriesPlaylistId\":\"series-tep-EG75YWMKNN\",\"tvSeriesUId\":\"pc47b41e9-8413-547f-8341-5185091eef8f\",\"tvSeriesName\":\"茂七の事件簿・新ふしぎ草紙\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[{\"name\":\"NHKドラマ\",\"url\":\"https://www.nhk.jp/g/drama/\"},{\"name\":\"「茂七の事件簿 ふしぎ草紙」HPはこちら\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-YNR772LN4V\"},{\"name\":\"ドラマ情報　再放送のお知らせ\",\"url\":\"https://www.nhk.jp/g/blog/o__p0y6p5c7/\"},{\"name\":\"【ドラマセレクション】再放送番組情報\",\"url\":\"https://www.nhk.jp/g/blog/drama-selection/\"}],\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-EG75YWMKNN\",\"description\":\"江戸の下町に起こる摩訶不思議な事件の数々を、茂七親分が人情味豊かに解決していく、怖くて、温かくて、せつない、「ふしぎ人情時代劇」。 シリーズ第二弾。\\n\\n【原作】\\n宮部みゆき\\n「かまいたち」「本所深川ふしぎ草紙」「幻色江戸ごよみ」「堪忍箱」より\\n\\n【脚本】\\n金子成人\\n\\n【音楽】\\n坂田晃一\\n\\n【語り】\\n春風亭小朝\\n\\n【主題歌】\\n「でんでん虫」\\n唄：氷川きよし　作詞：阿久悠　作・編曲：坂田晃一\\n\\n【初回放送】\\n2002年6月28日\\n総合テレビ　金曜　午後９時15分～10時\",\"detailedCatch\":\"ご存じ、回向院の茂七親分が帰って来た！\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/EG75YWMKNN/EG75YWMKNN-logo_27bdb12182ef615a286ffe2100c2086f.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/EG75YWMKNN/EG75YWMKNN-logo_da9df7775b3a2bf61a504451e38d5577.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/EG75YWMKNN/EG75YWMKNN-logo_5fe44fba34ca7d666ffa9e51fe0b02cf.png\",\"width\":200,\"height\":200}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/EG75YWMKNN/EG75YWMKNN-eyecatch_3bffd2737d5da82dd083758dfd040164.png\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/EG75YWMKNN/EG75YWMKNN-ey