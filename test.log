catches_e1390be9f65f79730dfe0500f8b9ae8b.jpg","width":640,"height":360}},{"large":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/Y6WYN5Z4VY/Y6WYN5Z4VY-eyecatches_241de19b30e3fe392f2070c0396bf3bc.jpg","width":3840,"height":2160},"main":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/Y6WYN5Z4VY/Y6WYN5Z4VY-eyecatches_17977d49f65ce3421b4da1c9b0f07951.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/Y6WYN5Z4VY/Y6WYN5Z4VY-eyecatches_d30fa1b0ab2a87a67febfc8db2c26580.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/Y6WYN5Z4VY/Y6WYN5Z4VY-eyecatches_1050806a95c412e255296c78b0912256.jpg","width":640,"height":360}}],"video":[{"id":"hskOriginal-g1-130-2026030408411","name":"【連続テレビ小説】ばけばけ（１０８）第２２週「アタラシ、ノ、ジンセイ。」","description":"ラン（蓮佛美沙子）の家の帰り道に、動けなくなってしまったトキ（髙石あかり）。通りかかった丈（杉田雷麟）と正木（日高由起刀）に連れられ病院で診察を受ける。大きな病かと不安なトキだったが、診察の結果、新たな命を授かったことを知る。家に帰ったトキの報告に、フミ（池脇千鶴）と司之介（岡部たかし）は歓喜する。しかし、トキはヘブン（トミー・バストウ）に告げるのは待ってほしいと家族に伝える。","url":"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/Y6WYN5Z4VY","identifierGroup":{"environmentId":"hskOriginal","broadcastEventId":"g1-130-2026030408411","serviceId":"g1","streamType":"vod"},"detailedContentStatus":{"environmentId":"hskOriginal","streamType":"vod","contentStatus":"ready"},"detailedVideoDescriptor":"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260304/20db-1-3-07b8d0032b0bd94d76b033726da086a8/videoinfo-1d7e19098b7c96754a293655bea1ac71.json","expires":"2026-03-11T08:15:00+09:00","duration":"PT14M59S","startDate":"2026-03-04T08:00:00+09:00","endDate":"2026-03-04T08:15:00+09:00","isDivided":false,"publication":[{"id":"g1-130-2026030408411","url":"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030408411.json","isLiveBroadcast":true}],"hasPart":[],"uploadDate":"2026-03-04T08:15:00+09:00"}],"citation":[],"detailedPinnedCitation":[{"name":"✨登場人物・キャスト","url":"https://www.nhk.jp/g/ts/662ZX5J