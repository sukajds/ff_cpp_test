static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_ac50df42a847591acd41059211e119f4.jpg\",\"width\":640,\"height\":360}}],\"video\":[{\"id\":\"hskOriginal-g1-130-2026030609560\",\"name\":\"【連続テレビ小説】ばけばけ（１１０）第２２週「アタラシ、ノ、ジンセイ。」\",\"description\":\"あっという間に半年が過ぎ、トキ（髙石あかり）は出産の日を迎える。ヘブン（トミー・バストウ）や司之介（岡部たかし）、丈（杉田雷麟）、正木（日高由起刀）は、無事の出産を祈り家の柱に向かう。フミ（池脇千鶴）、クマ（夏目透羽）、産婆（原ふき子）が見守る中、ついに、トキとヘブンの子供が産まれる！可愛らしい二人の子供に、デレデレになる松野家一同。そんな中、正木があることに気づく。\",\"url\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/PM8G32LN9N\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030609560\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"ready\"},\"detailedVideoDescriptor\":\"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260306/2558-1-3-0c0fdd97e90a63f3bd2821ba84324849/videoinfo-27f13bdebc198a3f72b4bc484a9a7bdf.json\",\"expires\":\"2026-03-13T08:15:00+09:00\",\"duration\":\"PT14M59S\",\"startDate\":\"2026-03-06T08:00:00+09:00\",\"endDate\":\"2026-03-06T08:15:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030609560\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030609560.json\",\"isLiveBroadcast\":true}],\"hasPart\":[],\"uploadDate\":\"2026-03-06T08:15:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[{\"name\":\"✨登場人物・キャスト\",\"url\":\"https://www.nhk.jp/g/ts/662ZX5J3WG/blog/bl/p63MOdwNjk/bp/pnyMroAvAn/\"},{\"name\":\"📺関連番組・インタビューはこちらから\",\"url\":\"https://www.nhk.jp/g/ts/662ZX5J3WG/blog/bl/p7xRqmNdbW/\"},{\"name\":\"📢ＮＨＫオンデマンドでは第1回から配信中\",\"url\":\"https://www.nhk-ondemand.jp/program/P202500475400000/\"}],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/PM8G32LN9N.json\",\"canonical\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/PM8G32LN9N\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/PM8G32LN9N\"}}]\n"])</script><script>self.__next_f.push([1,"53:[\"$\",\"$L2a\",\"M74M5M66JN\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"M74M5M66JN\",\"name\":\"(109)第22週「アタラシ、ノ、ジンセイ。」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"M74M5M66JN\",\"tvSeriesId\":\"662ZX5J3WG\",\"tvEpisodeName\":\"(109)第22週「アタラシ、ノ、ジンセイ。」\",\"tvSeriesName\":\"ばけばけ\",\"hashtag\":[],\"siteId\":\"0006\",\"serviceId\":[\"g1\",\"g2\",\"s1\",\"s2\",\"s5\"],\"aliasId\":\"bakebake\",\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"},{\"id\":\"030\",\"name\":\"ドラマ全般\"}]},\"keyword\":[],\"description\":\"ラン（蓮佛美沙子）から、トキ（髙石あかり）がフィリピンの話を全て知っていると聞かされたヘブン（トミー・バストウ）。ランにも背中を押され、ヘブンはトキを日本に残しフィリピンに旅立つことを決意する。一方、トキもまた生まれる子供と家族たちと日本に残り、ヘブンの作家活動を応援することを決意する。互いに決意を告げるため、トキとヘブンは散歩に出かける。\",\"dateCreated\":\"2025-12-12T18:16:12+09:00\",\"dateModified\":\"2026-02-26T07:30:17+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"662ZX5J3WG\",\"name\":\"ばけばけ\",\"detailedSeriesNameRuby\":\"ばけばけ\",\"identifierGroup\":{\"tvSeriesId\":\"662ZX5J3WG\",\"tvSeriesPlaylistId\":\"series-tep-662ZX5J3WG\",\"tvSeriesUId\":\"p97f04323-5f03-5c6a-ae95-69101ff72127\",\"tvSeriesName\":\"ばけばけ\",\"hashtag\":[],\"siteId\":\"0006\",\"serviceId\":[\"g1\",\"g2\",\"s1\",\"s2\",\"s5\"],\"aliasId\":\"bakebake\",\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[],\"canonical\":\"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG\",\"description\":\"【ＮＨＫ朝ドラ公式】連続テレビ小説「ばけばけ」。主演は髙石あかり。\\nキャスト相関図・見逃し配信・あらすじ・放送予定など。\\n小泉セツ\u0026八雲（ラフカディオ・ハーン）夫妻がモデルの物語。明治の松江。怪談を愛する夫婦の何気ない日常を描きます。\\n\\n【作】ふじきみつ彦\\n【音楽】牛尾憲輔\\n【主題歌】ハンバート ハンバート「笑ったり転んだり」\\n【キャスト】髙石あかり、トミー・バストウ / 吉沢亮　ほか\\n【放送予定】2025年9月29日（月）放送開始 （全25週125回）\",\"detailedCatch\":\"「この世はうらめしい。けど、すばらしい。」\",\"logo\":{\"main\":{\"url\":\"https:/