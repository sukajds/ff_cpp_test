77X8/NLX94G77X8-eyecatches_13660a5c22b2192dc612bdd4cb0804f0.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/NLX94G77X8/NLX94G77X8-eyecatches_5e4ab6f09fd50f25089d685b96c4faad.jpg\",\"width\":640,\"height\":360}}],\"video\":[{\"id\":\"hskOriginal-e1-130-2026030107169\",\"name\":\"超能力ファミリー　サンダーマン　～秘密大作戦（９）「フレンドはどこ？」\",\"description\":\"クロエはどこに行くにもフィービーとマックスがくっついてきてうんざり。そこで２人に新しく友だちを作るように提案する。納得したフィービーとマックスはそれぞれ友だち探しをスタート。そして友だちになれそうな人を見つけたのだが…。一方、やっと家で１人の時間を楽しめると思ったクロエだったが、ペリカンが入り込んで居座ってしまう。\",\"url\":\"https://www.web.nhk/tv/an/thundermans-undercover/pl/series-tep-J5N1R29NKP/ep/NLX94G77X8\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"e1-130-2026030107169\",\"serviceId\":\"e1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"ready\"},\"detailedVideoDescriptor\":\"https://archive.hsk.st.nhk/npd3/7fe1-0408/20260301/1c01-1-3-d56b038ceedbd23940bdd291a31bb23b/videoinfo-a0b18a8d0e011556fe2990bdfbd7218f.json\",\"expires\":\"2026-03-08T17:48:00+09:00\",\"duration\":\"PT22M59S\",\"startDate\":\"2026-03-01T17:25:00+09:00\",\"endDate\":\"2026-03-01T17:48:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"e1-130-2026030107169\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/e1-130-2026030107169.json\",\"isLiveBroadcast\":true}],\"hasPart\":[],\"uploadDate\":\"2026-03-01T17:48:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/NLX94G77X8.json\",\"canonical\":\"https://www.web.nhk/tv/an/thundermans-undercover/pl/series-tep-J5N1R29NKP/ep/NLX94G77X8\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/an/thundermans-undercover/pl/series-tep-J5N1R29NKP/ep/NLX94G77X8\"}}]\n"])</script><script>self.__next_f.push([1,"62:[\"$\",\"$L2a\",\"KVK69J5V99\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"KVK69J5V99\",\"name\":\"(8)「ユア・スパイズ・オンリー」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"KVK69J5V99\",\"tvSeriesId\":\"J5N1R29NKP\",\"tvEpisodeName\":\"(8)「ユア・スパイズ・オンリー」\",\"tvSeriesName\":\"超能力ファミリー サンダーマン 〜秘密大作戦\",\"hashtag\":[],\"serviceId\":[\"e1\",\"e3\"],\"aliasId\":\"thundermans-undercover\",\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"032\",\"name\":\"海外ドラマ\"}]},\"keyword\":[],\"description\":\"学校で保護者会が行われることに。フィービーとマックスは保護者にいいところを見せようと張り切るが、そこにやってきたのは人を解雇することが趣味のファーガソン教育長。２人は何とか気に入られようと奮闘するが…。一方、家ではクロエがジンクスとコンブチャを呼んで大はしゃぎ。だが、コンブチャはコロッソを見つけてしまい、ジンクスはエアラボを発見する。\",\"dateCreated\":\"2026-01-15T18:24:26+09:00\",\"dateModified\":\"2026-02-15T08:00:06+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"J5N1R29NKP\",\"name\":\"超能力ファミリー サンダーマン 〜秘密大作戦\",\"detailedSeriesNameRuby\":\"ちょうのうりょくふぁみりー　さんだーまん　ひみつだいさくせん\",\"identifierGroup\":{\"tvSeriesId\":\"J5N1R29NKP\",\"tvSeriesPlaylistId\":\"series-tep-J5N1R29NKP\",\"tvSeriesUId\":\"p76a1fcd4-86a1-50d8-9c0e-2fa284e5ff74\",\"tvSeriesName\":\"超能力ファミリー サンダーマン 〜秘密大作戦\",\"hashtag\":[],\"serviceId\":[\"e1\",\"e3\"],\"aliasId\":\"thundermans-undercover\",\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[],\"canonical\":\"https://www.web.nhk/tv/an/thundermans-undercover/pl/series-tep-J5N1R29NKP\",\"description\":\"シークレットショアーズという町で邪悪な通信が検知された。フィービーとマックスは、ヒーロー連盟のキックバット会長の命令でその町に潜入捜査に向かうことに。２人はクロエも連れて行くことにする。というのも、クロエの周りにはサンダーマンの知名度を目当てに近づいてくる友だちばかりで、クロエに普通の子と同じように暮らしてもらいたいという思いがあった。さらにそこに押しかけるようにドクター・コロッソもついて来ることに。どうやらコロッソは謎の人物と連絡をとりあっているようだが…。\\n\\n原題：The Thundermans : Undercover\\n制作：2025年 アメリカ\\n\",\"detailedCatch\":\"帰ってきた「サンダーマン」 フィービー、マックス、クロエが素性を隠して秘密の捜査！[全13回]\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-logo_74ef06fd440caaa9d97aff4c5c2ab3df.jpg\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-logo_fdc105e2b68bcecc5d39610a9382e988.jpg\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-logo_6c1e491f9fc15c1c386355d4d873b3bf.jpg\",\"width\":200,\"height\":200}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-eyecatch_2a3aff5a26f88a0aeafc1d758b24dfa2.jpg\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-eyecatch_89a09384518ac9ecb0401835548ddef4.jpg\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-eyecatch_4dd6526e212839c55f632034bfa30710.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-eyecatch_7c51081d1ae4c70360cc8281b602ddf3.jpg\",\"width\":640,\"height\":360}},\"hero\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-hero_6deb1b6d80946924f01be4c469081808.jpg\",\"width\":1920,\"height\":640},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/J5N1R29NKP/J5N1R29NKP-hero_34fef2285dc63b8abeb2e4185ae1a92a.jpg\",\"width\":1080,\"height\":360}},\"style\":{\"textLight\":\"#000000\",\"textDark\":\"#FFFFFF\",\"linkLight\":\"#E72400\",\"linkDark\":\"#FF4928\",\"primaryLight\":\"#FF2800\",\"primaryDark\":\"#FF2800\"},\"additionalProperty\":{\"publishLevel\":\"full\",\"layoutPattern\":\"summary\",\"episodeOrderBy\":\"releasedEvent\",\"availableOnPlus\":false,\"enableVariablePlayBackSpeedControl\":false,\"optional\":[],\"seriesPackStatus\":\"notPacked\",\"supportMedia\":[\"@screen\"],\"supportMusicList\":true,\"supportPlusEmbed\":true,\"enableWebContent\":false},\"url\":\"https://