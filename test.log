8L56W/RKWMR8L56W-eyecatches_6e9f338a40e04289b0ff8cb5af80cb5c.jpg","width":640,"height":360}},{"large":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/RKWMR8L56W/RKWMR8L56W-eyecatches_7df6a7ffe3cb44f109fb6dea28989eef.jpg","width":3840,"height":2160},"main":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/RKWMR8L56W/RKWMR8L56W-eyecatches_18cbb15a8c606e6575951d9616b0a040.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/RKWMR8L56W/RKWMR8L56W-eyecatches_e72617ad511b136abef7ce275e581a4a.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/RKWMR8L56W/RKWMR8L56W-eyecatches_1d212d4e7ae7be86bff8014030f6ab8c.jpg","width":640,"height":360}}],"video":[{"id":"hskOriginal-g1-130-2026031212802","name":"【連続テレビ小説】ばけばけ（１１４）第２３週「ゴブサタ、ニシコオリサン。」","description":"知事（佐野史郎）に、ヘブン（トミー・バストウ）が日本人になる許可をもらいに訪れたトキ（髙石あかり）とヘブン。しかし、取り付く島もなく一蹴されてしまう。錦織（吉沢亮）に協力を頼もうと中学校を訪れたトキは、そこでサワ（円井わん）と再会する。やはり、錦織に断られてしまうトキ。失意の中、トキとヘブンの元に勘右衛門（小日向文世）が訪ねてくる。日本人になるヘブンに、勘右衛門は名前を考えてきたと告げる。","url":"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/RKWMR8L56W","identifierGroup":{"environmentId":"hskOriginal","broadcastEventId":"g1-130-2026031212802","serviceId":"g1","streamType":"vod"},"detailedContentStatus":{"environmentId":"hskOriginal","streamType":"vod","contentStatus":"notyet"},"detailedVideoDescriptor":"https://simul.hsk.st.nhk/npd3/7fe0-0400/20260312/3202-1-1-0ba3c091aefa6ff315a813a096dd88a6/videoinfo-2992dc3d5c4b1be79e35954b371c5438.json","expires":"2026-03-19T08:15:00+09:00","duration":"PT15M","startDate":"2026-03-12T08:00:00+09:00","endDate":"2026-03-12T08:15:00+09:00","isDivided":false,"publication":[{"id":"g1-130-2026031212802","url":"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026031212802.json","isLiveBroadcast":true}],"uploadDate":"2026-03-12T08:15:00+09:00"}],"citation":[],"detailedPinnedCitation":[{"name":"✨登場人物・キャスト","url":"https://www.nhk.jp/g/