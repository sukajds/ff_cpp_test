1d:["$","$Lb","series-tep-M6Q9QR18KJ",{"spacing":"paragraph","children":[["$","$L10",null,{"title":"マッサン","link":{"href":"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ"}}],["$","$L11",null,{"itemWidth":{"mobile":171,"desktop":304},"children":[["$","$L12","XR8XKN3GJ4",{"content":{"type":"TVEpisode","id":"XR8XKN3GJ4","name":"(55)「灯台下(もと)暗し」","detailedEpisodeNameRuby":"","identifierGroup":{"tvEpisodeId":"XR8XKN3GJ4","tvSeriesId":"M6Q9QR18KJ","tvEpisodeName":"(55)「灯台下(もと)暗し」","tvSeriesName":"マッサン","hashtag":[],"serviceId":["g1","g2"],"formatGenreTag":[{"id":"03","name":"ドラマ"}],"themeGenreTag":[{"id":"031","name":"国内ドラマ"}]},"keyword":[],"description":"鴨居商店への入社が決まったマッサン（玉山鉄二）はスコットランドに風土が似た北海道に工場を建てたいと語り、エリー（シャーロット）は喜ぶ。さらに就職祝いにエリーに何かプレゼントをしたいとマッサンは提案するが、エリーはなぜか欲しい物を言い出せないのだった。工場長となったマッサンは、鴨居（堤真一）に工場の設立場所として北海道を、職人は広島から腕の良い蔵人を呼び寄せる計画を説明するのだが…。","dateCreated":"2026-02-10T18:36:12+09:00","dateModified":"2026-03-06T04:28:57+09:00","actor":[],"contributor":[],"partOfSeries":{"id":"M6Q9QR18KJ","name":"マッサン","detailedSeriesNameRuby":"まっさん","identifierGroup":{"tvSeriesId":"M6Q9QR18KJ","tvSeriesPlaylistId":"series-tep-M6Q9QR18KJ","tvSeriesUId":"pa6743cc6-ad8f-5002-822c-cb6b30d8a073","tvSeriesName":"マッサン","hashtag":[],"serviceId":["g1","g2"],"formatGenre":[{"id":"03","name":"ドラマ"}]},"keyword":[],"detailedSynonym":[],"sameAs":[{"name":"NHKドラマ","url":"https://www.nhk.jp/g/drama/"},{"name":"「マッサン」最新情報","url":"https://www.nhk.jp/g/ts/M6Q9QR18KJ/"},{"name":"ドラマ情報　玉山鉄二さんからのコメント","url":"https://www.nhk.jp/g/blog/fqgfs7y86/"},{"name":"ドラマ情報　シャーロット・ケイト・フォックスさんからのコメント","url":"https://www.nhk.jp/g/blog/rrzhcyiht/"},{"name":"NHKオンデマンド","url":"https://www.nhk-ondemand.jp/program/P201400118400000/"},{"name":"NHKアーカイブス","url":"https://www2.nhk.or.jp/archives/movies/?id=D0009050252_00000"},{"name":"【ドラマセレクション】再放送番組情報","url":"https://www.nhk.jp/g/blog/drama-selection/"}],"canonical":"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ","description":"単身スコットランドに渡り、ウイスキー醸造技術を学ぶ政春は、エリーと出会い恋に落ちる。国産初のウイスキー誕生を夢見るマッサンと、母国を離れ初めて日本にやってきたエリーには、次々と試練が待ち受けていた。\n激動の時代を夫婦の絆でまっすぐに生きるマッサンとエリーの愛と冒険の物語。\n\n【作】\n羽原大介\n\n【音楽】\n富貴晴美\n\n【主題歌】\n中島みゆき\n「麦の唄」\n\n【語り】\n松岡洋子\n\n【初回放送】\n2014年9月29日～2015年3月28日\n総合テレビ　「連続テレビ小説」にて放送","detailedCatch":"二人で、生きていくと　決めました","logo":{"main":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_8ed8218dcedc28acf1b6adf410691023.png","width":1080,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_68ab587945a461ec6fe4239efb1046e7.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_f946b2b1cddad1ef87204a57c18665f1.png","width":200,"height":200}},"eyecatch":{"large":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_3d94806a47d903d3ede263021a9ba99f.png","width":3840,"height":2160},"main":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_8b7ac0e1e8b04f61fb8f548c68f8ef29.png","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_697751101c554045386b9a594fb70f02.png","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_49fad15b7d619396d58ea34b5fdcf15f.png","width":640,"height":360}},"hero":{"main":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-hero_42ae1565bf62d137e628cb3aa198bb25.png","width":1920,"height":640},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-hero_5ca747184b97219204b980462f31f69b.png","width":1080,"height":360}},"style":{"textLight":"#000000","textDark":"#FFFFFF","linkLight":"#E72400","linkDark":"#FF4928","primaryLight":"#FF2800","primaryDark":"#FF2800"},"additionalProperty":{"publishLevel":"full","layoutPattern":"summary","episodeOrderBy":"releasedEvent","avail