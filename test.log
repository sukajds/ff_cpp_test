ain":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_9f649bf3dc1ce335d2fbbb811f7381ff.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_5e90ebe06a277c7dbe8c0c5369a34c80.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_d12bcf6a6b044930a317c235867f61a8.jpg","width":640,"height":360}},{"large":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_fab38216713a94a6940ee9a0f17f454f.jpg","width":3840,"height":2160},"main":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_f80ba5f8c8a4a84c40752822253b5978.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_5a06714853370127a63c5b36a28fc45a.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/PM8G32LN9N/PM8G32LN9N-eyecatches_ac50df42a847591acd41059211e119f4.jpg","width":640,"height":360}}],"video":[{"id":"hskOriginal-g1-130-2026030609560","name":"【連続テレビ小説】ばけばけ（１１０）第２２週「アタラシ、ノ、ジンセイ。」","description":"あっという間に半年が過ぎ、トキ（髙石あかり）は出産の日を迎える。ヘブン（トミー・バストウ）や司之介（岡部たかし）、丈（杉田雷麟）、正木（日高由起刀）は、無事の出産を祈り家の柱に向かう。フミ（池脇千鶴）、クマ（夏目透羽）、産婆（原ふき子）が見守る中、ついに、トキとヘブンの子供が産まれる！可愛らしい二人の子供に、デレデレになる松野家一同。そんな中、正木があることに気づく。","url":"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/PM8G32LN9N","identifierGroup":{"environmentId":"hskOriginal","broadcastEventId":"g1-130-2026030609560","serviceId":"g1","streamType":"vod"},"detailedContentStatus":{"environmentId":"hskOriginal","streamType":"vod","contentStatus":"ready"},"detailedVideoDescriptor":"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260306/2558-1-3-0c0fdd97e90a63f3bd2821ba84324849/videoinfo-27f13bdebc198a3f72b4bc484a9a7bdf.json","expires":"2026-03-13T08:15:00+09:00",