Part\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/an/thundermans-undercover/pl/series-tep-J5N1R29NKP/ep/3MM5Q63ZLR\"}}]\n"])</script><script>self.__next_f.push([1,"64:[\"$\",\"$L2a\",\"EV7122VJ6W\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"EV7122VJ6W\",\"name\":\"(6)「いけないチェリー」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"EV7122VJ6W\",\"tvSeriesId\":\"J5N1R29NKP\",\"tvEpisodeName\":\"(6)「いけないチェリー」\",\"tvSeriesName\":\"超能力ファミリー サンダーマン 〜秘密大作戦\",\"hashtag\":[],\"serviceId\":[\"e1\",\"e3\"],\"aliasId\":\"thundermans-undercover\",\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"032\",\"name\":\"海外ドラマ\"}]},\"keyword\":[],\"description\":\"フィービーの親友チェリーがシークレットショアーズに遊びに来る。２人は久しぶりの再会を喜ぶが、チェリーは以前手に入れたスーパーパワーを返していないことがわかる。一般人がパワーを持ったままだと危険なことが起こるかもしれないのだ。そんな中、フィービーとチェリーはクロエとコンブチャを誘ってハイテクなスパに行くが、そこで予想外のアクシデントが発生する！\",\"dateCreated\":\"2026-01-15T18:35:04+09:00\",\"dateModified\":\"2026-02-01T08:00:10+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"J5N1R29NKP\",\"name\":\"超能力ファミリー サンダーマン 〜秘密大作戦\",\"detailedSeriesNameRuby\":\"ちょうのうりょくふぁみりー　さんだーまん　ひみつだいさくせん\",\"identifierGroup\":{\"tvSeriesId\":\"J5N1R29NKP\",\"tvSeriesPlaylistId\":\"series-tep-J5N1R29NKP\",\"tvSeriesUId\":\"p76a1fcd4-86a1-50d8-9c0e-2fa284e5ff74\",\"tvSeriesName\":\"超能力ファミリー サンダーマン 〜秘密大作戦\",\"hashtag\":[],\"serviceId\":[\"e1\",\"e3\"],\"aliasId\":\"thundermans-undercover\",\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[],\"canonical\":\"https://www.web.nhk/tv/an/thundermans-undercover/pl/series-tep-J5N1R29NKP\",\"description\":\"シークレットショアーズという町で邪悪な通信が検知された。フィービーとマックスは、ヒーロー連盟のキックバット会長の命令でその町に潜入捜査に向かうことに。２人はクロエも連れて行くことにする。というのも、クロエの周りにはサンダーマンの知名度を目当てに近づいてくる友だちばかりで、クロエに普通の子と同じように暮らしてもらいたいという思いがあった。さらにそこに押しかけるようにドクター・コロッソもついて来ることに。どうやらコロッソは謎の人物と連絡をとりあっているようだが…。\\n\\n原題：The Thundermans : Undercover\\n制作：2025年 アメリカ\\n