assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_01b2129deac8fd6b35f079d701c13d1d.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_48705ab229afe9d0a0569df3b4fae613.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_0bf863128407afd59e37355642c392cc.png","width":200,"height":200}},"characterName":"柴田勝家","detailedCharacterNameRuby":"しばた かついえ","description":"兄弟の前に立ちはだかる大きな壁\n織田信長の重臣の一人。勇猛果敢な戦上手で「鬼柴田」の異名で恐れられた。足軽時代の小一郎と藤吉郎にとっては怖くて苦手な存在。やがて二人が出世を果たすとあからさまに毛嫌いするようになる。信長亡きあとの「清須会議」では後継者争いを繰り広げ、やがて「賤ケ岳の戦い」で兄弟と激突することになる。","detailedWork":[],"hasOccupation":[]}},{"person":{"identifierGroup":{"npgId":"F8A68291-926B-4D78-92E8-DA8D8B46ABAF","wikidataId":"Q457825"},"roleName":"Actor","displayRoleName":"俳優","name":"小栗 旬","detailedNameRuby":"おぐり しゅん","familyName":"小栗","givenName":"旬","detailedFamilyNameRuby":"おぐり","detailedGivenNameRuby":"しゅん","detailedNameDescription":"","honorificSuffix":"","jobTitle":[],"memberOf":[],"image":{"main":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_2c46d4f27e6f2c5f45a77b355eeb2c7c.png","width":1080,"height":1080},"medium":{"url":"https://img.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_ff718d518053e3495527d1a6c04376f4.png","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-person_fe883e8cff9a2b76dbc7f08d1ff2af32.png","width":200,"height":200}},"characterName":"織田信長","detailedCharacterNameRuby":"おだ のぶなが","description":"天下一統を狙う孤高のカリスマ\n大胆で革新的な戦略と非凡なリーダーシップにより領土を拡大し、「天下布武」のスローガンのもと天下一統を目指したカリスマ的武将。立身出世を目指す小一郎（のちの秀長）と藤吉郎（のちの秀吉）兄弟にとって絶対的な主君である。当主争いで対立した弟を自らの手で殺害したという苦い過去を持っている。","detailedWork":[],"hasOccupation":[]}}],"contributor":[],"partOfSeries":{"id":"P52L88MYXY","name":"大河ドラマ「豊臣兄弟！」","detailedSeriesNameRuby":"とよとみきょうだい","identifierGroup":{"tvSeriesId":"P52L88MYXY","tvSeriesPlaylistId":"series-tep-P52L88MYXY","tvSeriesUId":"p0defc81f-a07b-55e0-b9a6-c7f75720f416","tvSeriesName":"大河ドラマ「豊臣兄弟！」","hashtag":[],"siteId":"8969","serviceId":["g1","g2","s1","s2","s5"],"aliasId":"toyotomi-kyodai","formatGenre":[{"id":"03","name":"ドラマ"}],"nod":{"id":"P202500491700000","url":"https://www.nhk-ondemand.jp/program/P202500491700000/"}},"keyword":["NHK","大河ドラマ","豊臣兄弟！","戦国時代","豊臣秀長","豊臣秀吉","八津弘幸","仲野太賀","池松壮亮","吉岡里帆","浜辺美波","白石聖","坂井真紀","宮澤エマ","大東駿介","松下洸平","山口馬木也","宮﨑あおい","小栗旬"],"detailedSynonym":[],"sameAs":[{"name":"▶︎公式Instagram アカウント","url":"https://www.instagram.com/nhk_toyotomi/"},{"name":"▶︎公式X（旧Twitter）アカウント","url":"https://x.com/nhk_toyotomi"},{"name":"▶︎NHK公式YouTube「豊臣兄弟！」プレイリスト","url":"https://www.youtube.com/playlist?list=PLcynJ47QaWNvaqX7QpxWQbRs1tHrRHgnb"}],"canonical":"https://www.web.nhk/tv/an/toyotomi-kyodai/pl/series-tep-P52L88MYXY","description":"【NHK公式】大河ドラマ「豊臣兄弟！」\n\n大河ドラマ第65作で描くのは、戦国時代のど真ん中!!\n強い絆で天下統一という偉業を成し遂げた豊臣兄弟の奇跡──\n夢と希望の下剋上（げこくじょう）サクセスストーリーです！\n\n主人公は天下人の弟・豊臣秀長（とよとみ・ひでなが）\n歴史にif（もしも）はないものの…\n\n『秀長が長生きしていれば豊臣家の天下は安泰だった』\n\nとまでいわしめた天下一の補佐役・秀長の目線で戦国時代をダイナミックに描く波乱万丈のエンターテインメント！\n\n【放送予定】\n2026年1月4日（日）スタート ※初回15分拡大版\n\n【作】八津弘幸\n【音楽】木村秀彬\n【語り】安藤サクラ\n【出演】仲野太賀、池松壮亮、吉岡里帆、浜辺美波、白石 聖、坂井真紀、宮澤エマ、菅田将暉、大東駿介、松下洸平、山口馬木也、宮﨑あおい、小栗 旬　ほか\n【時代考証】黒田基樹、柴 裕之\n【制作統括】松川博敬、堀内裕介\n【プロデューサー】高橋優香子、舟橋哲男、吉岡和彦（展開・プロモーション）、国友 茜（広報）\n【演出】渡邊良雄、渡辺哲也、田中 正","detailedCatch":"熱い兄弟が夢と希望を胸に突っ走る奇跡の下剋上サクセスストーリー！","logo":{"main":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_c64ecc100161d9ce85c8aa953bc73ae1.jpg","width":1080,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_64a636dd72417d3cf661cb2f6808c33a.jpg","width":640,"height":640},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/P52L88MYXY/P52L88MYXY-logo_b696c913daeb18f3a663376fa0ec438b.jpg","width":200,"height":200}},"eyecatch":{"large":{"url":"https://imgu.web.nhk/st