l\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-eyecatch_640x360.png\",\"width\":640,\"height\":360}},\"hero\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero.svg\",\"main\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero_1920x640.png\",\"width\":1920,\"height\":640},\"medium\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero_1080x360.png\",\"width\":1080,\"height\":360}},\"badge9x4\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4.svg\",\"main\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4_360x160.png\",\"width\":360,\"height\":160},\"small\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4_180x80.png\",\"width\":180,\"height\":80}}}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/YX6ZXQ9G2P/YX6ZXQ9G2P-eyecatch_9e3b64d9040dc08cb7d4868378d593fb.jpg\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/YX6ZXQ9G2P/YX6ZXQ9G2P-eyecatch_b2a1b85c063a4d5f2bbc2d488b73564c.jpg\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/YX6ZXQ9G2P/YX6ZXQ9G2P-eyecatch_203ed2faef611e63a69e09f7eacdf064.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/YX6ZXQ9G2P/YX6ZXQ9G2P-eyecatch_5f6d8ca3c4ca56038f8ad940fe6ae742.jpg\",\"width\":640,\"height\":360}},\"eyecatchList\":[],\"video\":[{\"id\":\"hskOriginal-g1-130-2026030911762\",\"name\":\"【連続テレビ小説】マッサン（５１）「虎穴（こけつ）に入らずんば虎子を得ず」\",\"description\":\"マッサン（玉山鉄二）と鴨居（堤真一）の会談を成功させるため、最高のおもてなしをしたいとエリー（シャーロット）はキャサリン（濱田マリ）らに相談、早苗からもらった給金を使い料亭を借りることに。一方、鴨居商店がこの不景気のなか本当にウイスキーづくりができるのかという周囲の声を聞いたマッサンは、鴨居との会談に消極的。そんなマッサンにエリーはしった激励し、いよいよ会談の日を迎えるのだが…。\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/YX6ZXQ9G2P\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030911762\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"notyet\"},\"detailedVideoDescriptor\":\"https://simul.hsk.st.nhk/npd3/7fe0-0400/20260309/2df2-1-1-db7652239229c2be4fe73793e7b76eea/videoinfo-e752b190af8f304cadd09262b9811913.json\",\"expires\":\"2026-03-16T12:45:00+09:00\",\"duration\":\"PT15M\",\"startDate\":\"2026-03-09T12:30:00+09:00\",\"endDate\":\"2026-03-09T12:45:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030911762\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030911762.json\",\"isLiveBroadcast\":true}],\"uploadDate\":\"2026-03-09T12:45:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/YX6ZXQ9G2P.json\",\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/YX6ZXQ9G2P\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/YX6ZXQ9G2P\"}}]\n"])</script><script>self.__next_f.push([1,"59:[\"$\",\"$L2a\",\"X6N1QNMK69\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"X6N1QNMK69\",\"name\":\"(50)「虎穴(こけつ)に入らずんば虎子を得ず」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"X6N1QNMK69\",\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvEpisodeName\":\"(50)「虎穴(こけつ)に入らずんば虎子を得ず」\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"}]},\"keyword\":[],\"description\":\"鴨居（堤真一）とは一緒に働かないと意地を張るマッサン（玉山鉄二）に困るエリー（シャーロット）は鴨居商店に呼ばれ、スコットランドの貿易商と鴨居との会談の通訳をすることに。文化レベルが遅れた日本ではウイスキーをつくることなど無理だと主張する貿易商に対して、エリーは思わず通訳を忘れ反論し、鴨居もエリーに同調し追い返してしまう。そこでエリーは、もう一度マッサンにチャンスが欲しいと鴨居に懇願するのだった。\",\"dateCreated\":\"2026-02-04T18:15:00+09:00\",\"dateModified\":\"2026-02-27T04:29:26+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"M6Q9QR18KJ\",\"name\":\"マッサン\",\"detailedSeriesNameRuby\":\"まっさん\",\"identifierGroup\":{\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvSeriesPlaylistId\":\"series-tep-M6Q9QR18KJ\",\"tvSeriesUId\":\"pa6743cc6-ad8f-5002-822c-cb6b30d8a073\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[{\"name\":\"NHKドラマ\",\"url\":\"https://www.nhk.jp/g/drama/\"},{\"name\":\"「マッサン」最新情報\",\"url\":\"https://www.nhk.jp/g/ts/M6Q9QR18KJ/\"},{\"name\":\"ドラマ情報　玉山鉄二さんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/fqgfs7y86/\"},{\"name\":\"ドラマ情報　シャーロット・ケイト・フォックスさんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/rrzhcyiht/\"},{\"name\":\"NHKオンデマンド\",\"url\":\"https://www.nhk-ondemand.jp/program/P201400118400000/\"},{\"name\":\"NHKアーカイブス\",\"url\":\"https://www2.nhk.or.jp/archives/movies/?id=D0009050252_00000\"},{\"name\":\"【ドラマセレクション】再放送番組情報\",\"url\":\"https://www.nhk.jp/g/blog/drama-selection/\"}],\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ\",\"description\":\"単身スコットランドに渡り、ウイスキー醸造技術を学ぶ政春は、エリーと出会い恋に落ちる。国産初のウイスキー誕生を夢見るマッサンと、母国を離れ初めて日本にやってきたエリーには、次々と試練が待ち受けていた。\\n激動の時代を夫婦の絆でまっすぐに生きるマッサンとエリーの愛と冒険の物語。\\n\\n【作】\\n羽原大介\\n\\n【音楽】\\n富貴晴美\\n\\n【主題歌】\\n中島みゆき\\n「麦の唄」\\n\\n【語り】\\n松岡洋子\\n\\n【初回放送】\\n2014年9月29日～2015年3月28日\\n総合テレビ　「連続テレビ小説」にて放送\",\"detailedCatch\":\"二人で、生きていくと　決めました\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_8ed8218dcedc28acf1b6adf410691023.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_68ab587945a461ec6fe4239efb1046e7.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_f946b2b1cddad1ef87204a57c18665f1.png\",\"width\":200,\"height\":200}},