deo\":[{\"id\":\"hskOriginal-g1-130-2026030207702\",\"name\":\"事件は、その周りで起きている　シリーズ２（１）大反響コメディー小芝風花主演\",\"description\":\"新月署に設置された捜査本部が、犯人逮捕により撤収されることに。でも真野（小芝）は何やら機嫌が悪い様子。集まった捜査員のために真野が用意したあるものが不評で、大量に余ってしまったからだ。宇田川（笠松）や上司の谷崎（北村）からは「センスがない」とまで言われ、元科捜研のエース・向田（倉科）、真野に思いを寄せる徳大寺（中野）にも不機嫌をぶつける。その翌日、今度はセンスのいい“結婚祝い”が何かで大論争に…\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-R6ZNL4MY77/ep/Y6KZQ3XJ32\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030207702\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"ready\"},\"detailedVideoDescriptor\":\"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260302/1e16-1-3-c1d3b1d67bf0cf39728b1de7c4340532/videoinfo-9c5aa5eb80cd67de992622e0031a4827.json\",\"expires\":\"2026-03-09T23:00:00+09:00\",\"duration\":\"PT14M59S\",\"startDate\":\"2026-03-02T22:45:00+09:00\",\"endDate\":\"2026-03-02T23:00:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030207702\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030207702.json\",\"isLiveBroadcast\":true}],\"hasPart\":[],\"uploadDate\":\"2026-03-02T23:00:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/Y6KZQ3XJ32.json\",\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-R6ZNL4MY77/ep/Y6KZQ3XJ32\",\"associatedMedia\":[{\"id\":\"bcUploadTrailer1\",\"name\":\"事件は、その周りで起きている\",\"description\":\"シリーズ2 (1)/大反響コメディー・小芝風花主演\\n\",\"embedUrl\":\"https://www.nhk.jp/assets/players/bc/v3/index.html?account=6415847969001\u0026player=YVUjvvMQb\u0026videoId=6389947064112\",\"identifierGroup\":{\"environmentId\":\"bcUploadTrailer\",\"streamType\":\"clip\",\"bcAccountId\":\"6415847969001\",\"bcVideoId\":\"6389947064112\"},\"detailedContentStatus\":{\"environmentId\":\"bcUploadTrailer\",\"streamType\":\"clip\",\"contentStatus\":\"ready\"},\