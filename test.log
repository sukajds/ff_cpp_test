ages/tvepisode/te/EXJ35L6GLQ/EXJ35L6GLQ-eyecatches_6aa3febcfb655ecd04baafb371e3ff67.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/EXJ35L6GLQ/EXJ35L6GLQ-eyecatches_4f69170c9f9e6141ebcecbebcf4b9023.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/EXJ35L6GLQ/EXJ35L6GLQ-eyecatches_b4de38e2c4ee5ff8fb1c0580712054a2.jpg","width":640,"height":360}}],"video":[{"id":"hskOriginal-g1-130-2026031012099","name":"【連続テレビ小説】ばけばけ（１１２）第２３週「ゴブサタ、ニシコオリサン。」","description":"トキ（髙石あかり）と勘太と家族になるために、ヘブン（トミー・バストウ）は日本人になることを決める。２人が籍を入れるためには松江市役所での手続きが必要。トキとヘブンは、司之介（岡部たかし）、フミ（池脇千鶴）を連れ久しぶりに松江を訪れる。それは、錦織（吉沢亮）との再会を意味していた。松江を訪れた一行は、まずは宿をとりに懐かしの花田旅館を訪れる。","url":"https://www.web.nhk/tv/an/bakebake/pl/series-tep-662ZX5J3WG/ep/EXJ35L6GLQ","identifierGroup":{"environmentId":"hskOriginal","broadcastEventId":"g1-130-2026031012099","serviceId":"g1","streamType":"vod"},"detailedContentStatus":{"environmentId":"hskOriginal","streamType":"vod","contentStatus":"notyet"},"detailedVideoDescriptor":"https://simul.hsk.st.nhk/npd3/7fe0-0400/20260310/2f43-1-1-fa9acddc3f07d5edf3e74560cc64969f/videoinfo-8f5e0156e8aff8e6581e5cd2f523bbd1.json","expires":"2026-03-17T08:15:00+09:00","duration":"PT15M","startDate":"2026-03-10T08:00:00+09:00","endDate":"2026-03-10T08:15:00+09:00","isDivided":false,"publication":[{"id":"g1-130-2026031012099","url":"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026031012099.json","isLiveBroadcast":true}],"uploadDate":"2026-03-10T08:15:00+09:00"}],"citation":[],"detailedPinnedCitation":[{"name":"✨登場人物・キャスト","url":"https://www.nhk.jp/g/ts/662ZX5J3WG/blog/bl/p63MOdwNjk/bp/pnyMroAvAn/"},{"name":"📺関連番組・インタビューはこちらから","url":"https://www.nhk.jp/g/ts/662ZX5J3WG/blog/bl/p7xRqmNdbW/"},{"name":"📢ＮＨＫオンデマンドでは第1回から配信中","url":"https://www.nhk-ondemand.jp/program/P202500475400000/"}],"sameAs":[],"correction":[],"url":"https://api-local.ss.org.nhk/r8/t/tvepisode/te/EXJ35L6GLQ.json","can