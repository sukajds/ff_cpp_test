l\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/9945517Y13/9945517Y13-eyecatch_7acde02484c3d445830e5ff45b188e1a.jpg\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/9945517Y13/9945517Y13-eyecatch_29ad9960be7fe5bb7973745598073d8c.jpg\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/9945517Y13/9945517Y13-eyecatch_749023efc168c3c7a7844e2b2c4c0e49.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/9945517Y13/9945517Y13-eyecatch_4ab9d6daf492f2cb98697200edcb8bdd.jpg\",\"width\":640,\"height\":360}},\"eyecatchList\":[],\"video\":[{\"id\":\"hskOriginal-g1-130-2026030408456\",\"name\":\"【連続テレビ小説】マッサン（４８）「絵に描いた餅」\",\"description\":\"エリー（シャーロット）と二人の子どものことを考え、実家に帰ってくると早苗（泉ピン子）と政志（前田吟）に告げるマッサン（玉山鉄二）。しかし、政志と早苗はその申し出を受け付けず、大阪へ帰れと告げる。さらに、政志は蔵の仕事を手伝わせた真意をマッサンに語り、その言葉を聞いたマッサンはウイスキーづくりへの情熱がこみ上げてくるのだった。そして、エリーとマッサンはもう一度二人の未来について話し合う。\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/9945517Y13\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030408456\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"ready\"},\"detailedVideoDescriptor\":\"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260304/2108-1-3-4c1209000eedbf395c613198cd6c8540/videoinfo-108f36051357a979952423506508054c.json\",\"expires\":\"2026-03-11T12:45:00+09:00\",\"duration\":\"PT14M59S\",\"startDate\":\"2026-03-04T12:30:00+09:00\",\"endDate\":\"2026-03-04T12:45:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030408456\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030408456.json\",\"isLiveBroadcast\":true}],\"hasPart\":[],\"uploadDate\":\"2026-03-04T12:45:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/9945517Y13.json\",\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/9945517Y13\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/9945517Y13\"}}]\n"])</script><script>self.__next_f.push([1,"5c:[\"$\",\"$L2a\",\"NWRJ34ZLV4\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"NWRJ34ZLV4\",\"name\":\"(47)「絵に描いた餅」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"NWRJ34ZLV4\",\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvEpisodeName\":\"(47)「絵に描いた餅」\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"}]},\"keyword\":[],\"description\":\"千加子（西田尚美）の子どもが無事に生まれ喜ぶ亀山家一同。しかし、赤ん坊を抱くエリー（シャーロット）の姿を見て、マッサン（玉山鉄二）は小さな不安を抱くのだった。その変化に気づいた千加子はマッサンを呼び出し、二人に子どもができたときのことを考えるなら、広島の実家に帰って酒蔵を継ぐべきだ、そうすれば早苗（泉ピン子）も許してくれると提案する。二人は話し合い、エリーはマッサンについていくと告げるのだが…。\",\"dateCreated\":\"2026-02-04T18:36:00+09:00\",\"dateModified\":\"2026-02-24T04:33:22+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"M6Q9QR18KJ\",\"name\":\"マッサン\",\"detailedSeriesNameRuby\":\"まっさん\",\"identifierGroup\":{\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvSeriesPlaylistId\":\"series-tep-M6Q9QR18KJ\",\"tvSeriesUId\":\"pa6743cc6-ad8f-5002-822c-cb6b30d8a073\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[{\"name\":\"NHKドラマ\",\"url\":\"https://www.nhk.jp/g/drama/\"},{\"name\":\"「マッサン」最新情報\",\"url\":\"https://www.nhk.jp/g/ts/M6Q9QR18KJ/\"},{\"name\":\"ドラマ情報　玉山鉄二さんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/fqgfs7y86/\"},{\"name\":\"ドラマ情報　シャーロット・ケイト・フォックスさんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/rrzhcyiht/\"},{\"name\":\"NHKオンデマンド\",\"url\":\"https://www.nhk-ondemand.jp/program/P201400118400000/\"},{\"name\":\"NHKアーカイブス\",\"url\":\"https://www2.nhk.or.jp/archives/movies/?id=D0009050252_00000\"},{\"name\":\"【ドラマセレクション】再放送番組情報\",\"url\":\"https://www.nhk.jp/g/blog/drama-selection/\"}],\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ\",\"description\":\"単身スコットランドに渡り、ウイスキー醸造技術を学ぶ政春は、エリーと出会い恋に落ちる。国産初のウイスキー誕生を夢見るマッサンと、母国を離れ初めて日本にやってきたエリーには、次々と試練が待ち受けていた。\\n激動の時代を夫婦の絆でまっすぐに生きるマッサンとエリーの愛と冒険の物語。\\n\\n【作】\\n羽原大介\\n\\n【音楽】\\n富貴晴美\\n\\n【主題歌】\\n中島みゆき\\n「麦の唄」\\n\\n【語り】\\n松岡洋子\\n\\n【初回放送】\\n2014年9月29日～2015年3月28日\\n総合テレビ　「連続テレビ小説」にて放送\",\"detailedCatch\":\"二人で、生きていくと　決めました\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_8ed8218dcedc28acf1b6adf410691023.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_68ab587945a461ec6fe4239efb1046e7.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_f946b2b1cddad1ef87204a57c18665f1.png\",\"width\":200,\"height\":200}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_3d94806a47d903d3ede263021a9ba99f.png\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_8b7ac0e1e8b04f61fb8f548c68f8ef29.png\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_697751101c554045386b9a594fb70f02.png\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_49fad15b7d619396d58ea34b5fdcf15f.png\",\"width\":640,\"height\":360}},\"hero\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-hero_42ae1565bf62d