width\":640,\"height\":360}},\"eyecatchList\":[],\"video\":[{\"id\":\"hskOriginal-g1-130-2026031212834\",\"name\":\"【連続テレビ小説】マッサン（５４）「虎穴（こけつ）に入らずんば虎子を得ず」\",\"description\":\"鴨居とともに働くことを決意したマッサン（玉山鉄二）は、エリー（シャーロット）と一緒に報告のため広島の実家へと向かう。早苗（泉ピン子）はなぜか上機嫌。しかし、鴨居商店に就職し本格的にウイスキーづくりを始めると報告した途端、ついに夢と結婚を諦め酒蔵を継ぐ気になったと勘違いしていた早苗は不機嫌に。そして、早苗は「どうして外国人に生まれてきたんじゃ」と複雑な思いをエリーにぶつけるのだった。\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/JR12XJ436Y\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026031212834\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"notyet\"},\"detailedVideoDescriptor\":\"https://simul.hsk.st.nhk/npd3/7fe0-0400/20260312/3222-1-1-aafb66df3e4e4287b1b158c943976fca/videoinfo-4bddb65f039be81875c1c9105b74184d.json\",\"expires\":\"2026-03-19T12:45:00+09:00\",\"duration\":\"PT15M\",\"startDate\":\"2026-03-12T12:30:00+09:00\",\"endDate\":\"2026-03-12T12:45:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026031212834\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026031212834.json\",\"isLiveBroadcast\":true}],\"uploadDate\":\"2026-03-12T12:45:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/JR12XJ436Y.json\",\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/JR12XJ436Y\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/JR12XJ436Y\"}}]\n"])</script><script>self.__next_f.push([1,"56:[\"$\",\"$L2a\",\"LJM3Z28JKP\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"LJM3Z28JKP\",\"name\":\"(53)「虎穴(こけつ)に入らずんば虎子を得ず」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"LJM3Z28JKP\",\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvEpisodeName\":\"(53)「虎穴(こけつ)に入らずんば虎子を得ず」\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"}]},\"keyword\":[],\"description\":\"月給百円の化学教師の仕事をエリー（シャーロット）のためにも引き受けるべきと周囲に促され思い悩むマッサン（玉山鉄二）。お金がないと生きていけないと、キャサリン（濱田マリ）らも引き受けるべきと言うが、鴨居（堤真一）と一緒にウイスキーづくりをして欲しいエリーは複雑。一方、鴨居もまたウイスキー技術者を探す中で、本場で修行をした男・マッサンなら日本でもウイスキーがつくれるのではと助言され、思い悩むのだった。\",\"dateCreated\":\"2026-02-10T18:36:12+09:00\",\"dateModified\":\"2026-03-04T04:36:50+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"M6Q9QR18KJ\",\"name\":\"マッサン\",\"detailedSeriesNameRuby\":\"まっさん\",\"identifierGroup\":{\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvSeriesPlaylistId\":\"series-tep-M6Q9QR18KJ\",\"tvSeriesUId\":\"pa6743cc6-ad8f-5002-822c-cb6b30d8a073\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[{\"name\":\"NHKドラマ\",\"url\":\"https://www.nhk.jp/g/drama/\"},{\"name\":\"「マッサン」最新情報\",\"url\":\"https://www.nhk.jp/g/ts/M6Q9QR18KJ/\"},{\"name\":\"ドラマ情報　玉山鉄二さんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/fqgfs7y86/\"},{\"name\":\"ドラマ情報　シャーロット・ケイト・フォックスさんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/rrzhcyiht/\"},{\"name\":\"NHKオンデマンド\",\"url\":\"https://www.nhk-ondemand.jp/program/P201400118400000/\"},{\"name\":\"NHKアーカイブス\",\"url\":\"https://www2.nhk.or.jp/archives/movies/?id=D0009050252_00000\"},{\"name\":\"【ドラマセレクション】再放送番組情報\",\"url\":\"https://www.nhk.jp/g/blog/drama-selection/\"}],\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ\",\"description\":\"単身スコットランドに渡り、ウイスキー醸造技術を学ぶ政春は、エリーと出会い恋に落ちる。国産初のウイスキー誕生を夢見るマッサンと、母国を離れ初めて日本にやってきたエリーには、次々と試練が待ち受けていた。\\n激動の時代を夫婦の絆でまっすぐに生きるマッサンとエリーの愛と冒険の物語。\\n\\n【作】\\n羽原大介\\n\\n【音楽】\\n富貴晴美\\n\\n【主題歌】\\n中島みゆき\\n「麦の唄」\\n\\n【語り】\\n松岡洋子\\n\\n【初回放送】\\n2014年9月29日～2015年3月28日\\n総合テレビ　「連続テレビ小説」にて放送\",\"detailedCatch\":\"二人で、生きていくと　決めました\",\"logo\":{\"main\":{