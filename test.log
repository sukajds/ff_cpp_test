:{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/MZL2731KJJ/MZL2731KJJ-eyecatch_c936eb18411bb27021e42d1b65ec6967.jpg","width":1920,"height":1080},"medium":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/MZL2731KJJ/MZL2731KJJ-eyecatch_c21b0480ef42aad2278180541b5882a2.jpg","width":1280,"height":720},"small":{"url":"https://imgu.web.nhk/static/assets/images/tvepisode/te/MZL2731KJJ/MZL2731KJJ-eyecatch_716f6782307da2c6ad222457b3c19b09.jpg","width":640,"height":360}},"eyecatchList":[],"video":[{"id":"hskOriginal-g1-130-2026030207661","name":"【連続テレビ小説】マッサン（４６）「絵に描いた餅」","description":"蔵の作業に弱音を吐くマッサン（玉山鉄二）に、俊夫（八嶋智人）は「いい年をして仕事もしていない人間に、未来の酒などつくれる訳がない」と言い放つ。一方、スコットランドに帰るよう早苗（泉ピン子）に説得されるも、帰りませんと告げるエリー（シャーロット）は、俊夫の言葉に落ち込むマッサンを励まし、千加子（西田尚美）に習った亀山家のみそ汁をマッサンに飲ませるのだった。そんなとき、千加子が産気づいて…。","url":"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/MZL2731KJJ","identifierGroup":{"environmentId":"hskOriginal","broadcastEventId":"g1-130-2026030207661","serviceId":"g1","streamType":"vod"},"detailedContentStatus":{"environmentId":"hskOriginal","streamType":"vod","contentStatus":"ready"},"detailedVideoDescriptor":"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260302/1ded-1-3-39dd4c38e7ff0a47b4613365db365873/videoinfo-2a045ab31b9b76b30291c98f23ddf934.json","expires":"2026-03-09T12:45:00+09:00","duration":"PT14M59S","startDate":"2026-03-02T12:30:00+09:00","endDate":"2026-03-02T12:45:00+09:00","isDivided":false,"publication":[{"id":"g1-130-2026030207661","url":"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030207661.json","isLiveBroadcast":true}],"hasPart":[],"uploadDate":"2026-03-02T12:45:00+09:00"}],"citation":[],"detailedPinnedCitation":[],"sameAs":[],"correction":[],"url":"https://api-local.ss.org.nhk/r8/t/tvepisode/te/MZL2731KJJ.json","canonical":"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/MZL2731KJJ","associatedMedia":[],"hasPart":[],"additionalProperty":{"episodeMergeStatus":"notMerged"}},"link":{"href":"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/MZL2731KJJ"}}]
46:["$","$L12","E6YP71XNZN",{"content":{"type":"TVEpisode","id":"E6YP71XNZN","name":"(3)「鬼子母火」","identifierGroup":{"tvEpisodeId":"E6YP71XNZN","tvSeriesId":"EG75YWMKNN","tvEpisodeName":"(3)「鬼子母火」","tvSeriesName":"茂七の事件簿・新ふしぎ草紙","hashtag":[],"serviceId":["g1","g2"],"formatGenreTag":[{"id":"03","name":"ドラマ"}],"themeGenreTag":[{"id":"031","name":"国内ドラマ"},{"id":"033","name":"時代劇"}]},"keyword":[],"description":"回向院の茂七（高橋英樹）は、新川の酒問屋・伊丹屋で起きたぼや騒ぎの真相を探ることになる。女中頭のおとよ（木の実ナナ）は、「内々で始末をつけるから関わらないで」というが、神棚のしめ縄に残された髪の毛を手がかりに、奉公人たちや店の内情を調べていく茂七。やがて事件の裏に潜む、人知れぬ思いと幼い奉公人の悲しい過去が浮かび上がる。茂七は江戸の町で起きた小さな火事に、人の情と向き合いながら決着をつけていく。","dateCreated":"2026-01-29T18:35:46+09:00","dateModified":"2026-02-22T04:41:00+09:00","actor":[],"contributor":[],"partOfSeries":{"id":"EG75YWMKNN","name":"茂七の事件簿・新ふしぎ草紙","detailedSeriesNameRuby":"もしちのじけんぼ　しんふしぎそうし","identifierGroup":{"tvSeriesId":"EG75YWMKNN","tvSeriesPlaylistId":"series-tep-EG75YWMKNN","tvSeriesUId":"pc47b41e9-8413-547f-8341-5185091eef8f","tvSeriesName":"茂七の事件簿・新ふしぎ草紙","hashtag":[],"serviceId":["g1","g2"],"formatGenre":[{"id":"03","name":"ドラマ"}]},"keyword":[],"detailedSynonym":[],"sameAs":[{"name":"NHKドラマ","url":"https://www.nhk.jp/g/drama/"},{"name":"「茂七の事件簿 ふしぎ草紙」HPはこちら","url":"https://www.web.nhk/tv/pl/series-tep-YNR772LN4V"},{"name":"ドラマ情報　再放送のお知らせ","url":"https://www.nhk.jp/g/blog/o__p0y6p5c7/"},{"name":"【ドラマセレクション】再放送番組情報","url":"https://www.nhk.jp/g/blog/drama-selection/"}],"canonical":"https://www.web.nhk/tv/pl/series-tep-EG75YWMKNN","description":"江戸の下町に起こる摩訶不思議な事件の数々を、茂七親分が人情味豊かに解決していく、怖くて、温かくて、せつない、「ふしぎ人情時代劇」。 シリーズ第二弾。\n\n【原作】\n宮部みゆき\n「かまいたち」「本所深川ふしぎ草紙」「幻色江戸ごよみ」「堪忍箱」より\n\n【脚本】\n金子成人\n\n【音楽】\n坂田晃一\n\n【語り】\n春風亭小朝\n\n【主題歌】\n「でんでん虫」\n唄：氷川きよし　作詞：阿久悠　作・編曲：坂田晃一\n\n【初回放送】\n2002年6月28日\n総合テレビ　金曜　午後９時15分～10時","detailedCatch":"ご存じ、回向院の茂七親分が帰って来た！","logo":{"main":{"url":"https://imgu.web.nhk/static/assets/images/tvseries/ts/EG75YWMKNN/EG75YWMKNN-logo_27bdb12182ef615a286ffe2100c2086f.png","width":1080,"height":1080},"medium":{"url":"https://imgu.web.nhk