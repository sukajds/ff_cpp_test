/imgu.web.nhk/static/assets/images/tvepisode/te/NWRJ34ZLV4/NWRJ34ZLV4-eyecatch_3c393852138b03883ecb4a50473403b7.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/NWRJ34ZLV4/NWRJ34ZLV4-eyecatch_8ca3ee75bea991a7d3ce62c0a4a602a7.jpg\",\"width\":640,\"height\":360}},\"eyecatchList\":[],\"video\":[{\"id\":\"hskOriginal-g1-130-2026030308068\",\"name\":\"【連続テレビ小説】マッサン（４７）「絵に描いた餅」\",\"description\":\"千加子（西田尚美）の子どもが無事に生まれ喜ぶ亀山家一同。しかし、赤ん坊を抱くエリー（シャーロット）の姿を見て、マッサン（玉山鉄二）は小さな不安を抱くのだった。その変化に気づいた千加子はマッサンを呼び出し、二人に子どもができたときのことを考えるなら、広島の実家に帰って酒蔵を継ぐべきだ、そうすれば早苗（泉ピン子）も許してくれると提案する。二人は話し合い、エリーはマッサンについていくと告げるのだが…。\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/NWRJ34ZLV4\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030308068\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"ready\"},\"detailedVideoDescriptor\":\"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260303/1f84-1-3-d5dc20885e411793c85b49b5a625de9f/videoinfo-d7ae81fc8ea00e2e292daaf55a13a366.json\",\"expires\":\"2026-03-10T12:45:00+09:00\",\"duration\":\"PT14M59S\",\"startDate\":\"2026-03-03T12:30:00+09:00\",\"endDate\":\"2026-03-03T12:45:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030308068\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030308068.json\",\"isLiveBroadcast\":true}],\"hasPart\":[],\"uploadDate\":\"2026-03-03T12:45:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/NWRJ34ZLV4.json\",\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/NWRJ34ZLV4\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/NWRJ34ZLV4\"}}]\n"])</script><script>self.__next_f.push([1,"5d:[\"$\",\"$L2a\",\"MZL2731KJJ\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"MZL2731KJJ\",\"name\":\"(46)「絵に描いた餅」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"MZL2731KJJ\",\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvEpisodeName\":\"(46)「絵に描いた餅」\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"}]},\"keyword\":[],\"description\":\"蔵の作業に弱音を吐くマッサン（玉山鉄二）に、俊夫（八嶋智人）は「いい年をして仕事もしていない人間に、未来の酒などつくれる訳がない」と言い放つ。一方、スコットランドに帰るよう早苗（泉ピン子）に説得されるも、帰りませんと告げるエリー（シャーロット）は、俊夫の言葉に落ち込むマッサンを励まし、千加子（西田尚美）に習った亀山家のみそ汁をマッサンに飲ませるのだった。そんなとき、千加子が産気づいて…。\",\"dateCreated\":\"2026-02-04T18:15:00+09:00\",\"dateModified\":\"2026-02-23T04:34:19+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"M6Q9QR18KJ\",\"name\":\"マッサン\",\"detailedSeriesNameRuby\":\"まっさん\",\"identifierGroup\":{\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvSeriesPlaylistId\":\"series-tep-M6Q9QR18KJ\",\"tvSeriesUId\":\"pa6743cc6-ad8f-5002-822c-cb6b30d8a073\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[{\"name\":\"NHKドラマ\",\"url\":\"https://www.nhk.jp/g/drama/\"},{\"name\":\"「マッサン」最新情報\",\"url\":\"https://www.nhk.jp/g/ts/M6Q9QR18KJ/\"},{\"name\":\"ドラマ情報　玉山鉄二さんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/fqgfs7y86/\"},{\"name\":\"ドラマ情報　シャーロット・ケイト・フォックスさんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/rrzhcyiht/\"},{\"name\":\"NHKオンデマンド\",\"url\":\"https://www.nhk-ondemand.jp/program/P201400118400000/\"},{\"name\":\"NHKアーカイブス\",\"url\":\"https://www2.nhk.or.jp/archives/movies/?id=D0009050252_00000\"},{\"name\":\"【ドラマセレクション】再放送番組情報\",\"url\":\"https://www.nhk.jp/g/blog/drama-selection/\"}],\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ\",\"description\":\"単身スコットランドに渡り、ウイスキー醸造技術を学ぶ政春は、エリーと出会い恋に落ちる。国産初のウイスキー誕生を夢見るマッサンと、母国を離れ初めて日本にやってきたエリーには、次々と試練が待ち受けていた。\\n激動の時代を夫婦の絆でまっすぐに生きるマッサンとエリーの愛と冒険の物語。\\n\\n【作】\\n羽原大介\\n\\n【音楽】\\n富貴晴美\\n\\n【主題歌】\\n中島みゆき\\n「麦の唄」\\n\\n【語り】\\n松岡洋子\\n\\n【初回放送】\\n2014年9月29日～2015年3月28日\\n総合テレビ　「連続テレビ小説」にて放送\",\"detailedCatch\":\"二人で、生きていくと　決めました\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_8ed8218dcedc28acf1b6adf410691023.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_68ab587945a461ec6fe4239efb1046e7.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_f946b2b1cddad1ef87204a57c18665f1.png\",\"width\":200,\"height\":200}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_3d94806a47d903d3ede263021a9ba99f.png\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_8b7ac0e1e8b04f61fb8f548c68f8ef29.png\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_697751101c554045386b9a594fb70f02.png\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_49fad15b7d619396d58ea34b5fdcf15f.png\",\"width\":640,\"height\":360}},\"hero\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-hero_42ae1565bf62d137e628cb3aa198bb25.png\",\"width\":1920,\"height\":640},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-hero_5ca747184b97219204b980462f31f69b.png\",\"width\":1080,\"height\":360}},\"style\":{\"textLight\":\"#000000\",\"textDark\":\"#FFFFFF\",\"linkLight\":\"#E72400\",\"linkDark\":\"#FF4928\",\"primaryLight\":\"#FF28