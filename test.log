ps://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero_1920x640.png\",\"width\":1920,\"height\":640},\"medium\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-hero_1080x360.png\",\"width\":1080,\"height\":360}},\"badge9x4\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4.svg\",\"main\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4_360x160.png\",\"width\":360,\"height\":160},\"small\":{\"url\":\"https://imgu.web.nhk/common/broadcastservice/bs/g1/g1-badge9x4_180x80.png\",\"width\":180,\"height\":80}}}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/GL7MR1V243/GL7MR1V243-eyecatch_28d94c4cced4f1d3074ebb287202eddf.jpg\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/GL7MR1V243/GL7MR1V243-eyecatch_82ede47b2ddeb897c4791d76253caa2b.jpg\",\"width\":1920,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/GL7MR1V243/GL7MR1V243-eyecatch_ddf9c782b03d1af35bf40714ad7cb49c.jpg\",\"width\":1280,\"height\":720},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvepisode/te/GL7MR1V243/GL7MR1V243-eyecatch_29aeea23b83af211025fd6bf2e87f863.jpg\",\"width\":640,\"height\":360}},\"eyecatchList\":[],\"video\":[{\"id\":\"hskOriginal-g1-130-2026030508963\",\"name\":\"【連続テレビ小説】マッサン（４９）「虎穴（こけつ）に入らずんば虎子を得ず」\",\"description\":\"ウイスキーづくりへの決意を新たに大阪へと向かうマッサン（玉山鉄二）とエリー（シャーロット）。やはり鴨居（堤真一）に頭を下げ雇ってもらうしかないと、マッサンは鴨居商店を訪れるがなかなか話を切り出せない。そんなとき、鴨居は一本の瓶を差し出しマッサンに試飲させる。ウイスキーと炭酸水を混ぜたこの飲み物を新商品として売り出すと聞いたマッサンは、ウイスキーを馬鹿にしていると激怒し出て行ってしまう。\",\"url\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/GL7MR1V243\",\"identifierGroup\":{\"environmentId\":\"hskOriginal\",\"broadcastEventId\":\"g1-130-2026030508963\",\"serviceId\":\"g1\",\"streamType\":\"vod\"},\"detailedContentStatus\":{\"environmentId\":\"hskOriginal\",\"streamType\":\"vod\",\"contentStatus\":\"ready\"},\"detailedVideoDescriptor\":\"https://archive.hsk.st.nhk/npd3/7fe0-0400/20260305/2303-1-3-34f894f7144342acc5cade7f988d6ec3/videoinfo-97c80907a94370cec201af8a9fcce713.json\",\"expires\":\"2026-03-12T12:45:00+09:00\",\"duration\":\"PT14M59S\",\"startDate\":\"2026-03-05T12:30:00+09:00\",\"endDate\":\"2026-03-05T12:45:00+09:00\",\"isDivided\":false,\"publication\":[{\"id\":\"g1-130-2026030508963\",\"url\":\"https://api-local.ss.org.nhk/r8/t/broadcastevent/be/g1-130-2026030508963.json\",\"isLiveBroadcast\":true}],\"hasPart\":[],\"uploadDate\":\"2026-03-05T12:45:00+09:00\"}],\"citation\":[],\"detailedPinnedCitation\":[],\"sameAs\":[],\"correction\":[],\"url\":\"https://api-local.ss.org.nhk/r8/t/tvepisode/te/GL7MR1V243.json\",\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/GL7MR1V243\",\"associatedMedia\":[],\"hasPart\":[],\"additionalProperty\":{\"episodeMergeStatus\":\"notMerged\"}},\"link\":{\"href\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ/ep/GL7MR1V243\"}}]\n"])</script><script>self.__next_f.push([1,"5b:[\"$\",\"$L2a\",\"9945517Y13\",{\"content\":{\"type\":\"TVEpisode\",\"id\":\"9945517Y13\",\"name\":\"(48)「絵に描いた餅」\",\"detailedEpisodeNameRuby\":\"\",\"identifierGroup\":{\"tvEpisodeId\":\"9945517Y13\",\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvEpisodeName\":\"(48)「絵に描いた餅」\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenreTag\":[{\"id\":\"03\",\"name\":\"ドラマ\"}],\"themeGenreTag\":[{\"id\":\"031\",\"name\":\"国内ドラマ\"}]},\"keyword\":[],\"description\":\"エリー（シャーロット）と二人の子どものことを考え、実家に帰ってくると早苗（泉ピン子）と政志（前田吟）に告げるマッサン（玉山鉄二）。しかし、政志と早苗はその申し出を受け付けず、大阪へ帰れと告げる。さらに、政志は蔵の仕事を手伝わせた真意をマッサンに語り、その言葉を聞いたマッサンはウイスキーづくりへの情熱がこみ上げてくるのだった。そして、エリーとマッサンはもう一度二人の未来について話し合う。\",\"dateCreated\":\"2026-02-04T18:36:00+09:00\",\"dateModified\":\"2026-02-25T04:42:34+09:00\",\"actor\":[],\"contributor\":[],\"partOfSeries\":{\"id\":\"M6Q9QR18KJ\",\"name\":\"マッサン\",\"detailedSeriesNameRuby\":\"まっさん\",\"identifierGroup\":{\"tvSeriesId\":\"M6Q9QR18KJ\",\"tvSeriesPlaylistId\":\"series-tep-M6Q9QR18KJ\",\"tvSeriesUId\":\"pa6743cc6-ad8f-5002-822c-cb6b30d8a073\",\"tvSeriesName\":\"マッサン\",\"hashtag\":[],\"serviceId\":[\"g1\",\"g2\"],\"formatGenre\":[{\"id\":\"03\",\"name\":\"ドラマ\"}]},\"keyword\":[],\"detailedSynonym\":[],\"sameAs\":[{\"name\":\"NHKドラマ\",\"url\":\"https://www.nhk.jp/g/drama/\"},{\"name\":\"「マッサン」最新情報\",\"url\":\"https://www.nhk.jp/g/ts/M6Q9QR18KJ/\"},{\"name\":\"ドラマ情報　玉山鉄二さんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/fqgfs7y86/\"},{\"name\":\"ドラマ情報　シャーロット・ケイト・フォックスさんからのコメント\",\"url\":\"https://www.nhk.jp/g/blog/rrzhcyiht/\"},{\"name\":\"NHKオンデマンド\",\"url\":\"https://www.nhk-ondemand.jp/program/P201400118400000/\"},{\"name\":\"NHKアーカイブス\",\"url\":\"https://www2.nhk.or.jp/archives/movies/?id=D0009050252_00000\"},{\"name\":\"【ドラマセレクション】再放送番組情報\",\"url\":\"https://www.nhk.jp/g/blog/drama-selection/\"}],\"canonical\":\"https://www.web.nhk/tv/pl/series-tep-M6Q9QR18KJ\",\"description\":\"単身スコットランドに渡り、ウイスキー醸造技術を学ぶ政春は、エリーと出会い恋に落ちる。国産初のウイスキー誕生を夢見るマッサンと、母国を離れ初めて日本にやってきたエリーには、次々と試練が待ち受けていた。\\n激動の時代を夫婦の絆でまっすぐに生きるマッサンとエリーの愛と冒険の物語。\\n\\n【作】\\n羽原大介\\n\\n【音楽】\\n富貴晴美\\n\\n【主題歌】\\n中島みゆき\\n「麦の唄」\\n\\n【語り】\\n松岡洋子\\n\\n【初回放送】\\n2014年9月29日～2015年3月28日\\n総合テレビ　「連続テレビ小説」にて放送\",\"detailedCatch\":\"二人で、生きていくと　決めました\",\"logo\":{\"main\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_8ed8218dcedc28acf1b6adf410691023.png\",\"width\":1080,\"height\":1080},\"medium\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_68ab587945a461ec6fe4239efb1046e7.png\",\"width\":640,\"height\":640},\"small\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-logo_f946b2b1cddad1ef87204a57c18665f1.png\",\"width\":200,\"height\":200}},\"eyecatch\":{\"large\":{\"url\":\"https://imgu.web.nhk/static/assets/images/tvseries/ts/M6Q9QR18KJ/M6Q9QR18KJ-eyecatch_3d94806a47d903d3ede263021a9ba99f.png\",\"width\":3840,\"height\":2160},\"main\":{\"url\":\"https://imgu.web.n